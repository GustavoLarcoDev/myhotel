@{
    ViewData["Title"] = "Daily Checks";

    var checks = ViewBag.Checks as List<DailyCheck> ?? new List<DailyCheck>();
    var allChecks = ViewBag.AllChecks as List<DailyCheck> ?? new List<DailyCheck>();
    var filter = (string)ViewBag.Filter;
    var today = (string)ViewBag.Today;
    var totalCount = (int)ViewBag.TotalCount;
    var completedCount = (int)ViewBag.CompletedCount;
    var pendingCount = (int)ViewBag.PendingCount;
    var progressPercent = (int)ViewBag.ProgressPercent;

    var categories = new[] { "pool", "lobby", "elevator", "security", "fire", "parking", "housekeeping", "general" };

    string CategoryColor(string cat) => cat switch
    {
        "pool" => "teal",
        "lobby" => "blue",
        "elevator" => "gray",
        "security" => "red",
        "fire" => "orange",
        "parking" => "purple",
        "housekeeping" => "pink",
        "general" => "slate",
        _ => "gray"
    };

    string CategoryIcon(string cat) => cat switch
    {
        "pool" => "M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z",
        "lobby" => "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6",
        "elevator" => "M8 7l4-4m0 0l4 4m-4-4v18",
        "security" => "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
        "fire" => "M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z",
        "parking" => "M5 3h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2z",
        "housekeeping" => "M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16",
        "general" => "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z",
        _ => "M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
    };

    var grouped = checks.GroupBy(c => c.Category).OrderBy(g => Array.IndexOf(categories, g.Key)).ToList();

    // Circumference for the SVG circle (radius=45)
    double circumference = 2 * Math.PI * 45;
    double strokeDashoffset = circumference - (circumference * progressPercent / 100.0);
}

<!-- Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Daily Checks</h1>
        <p class="text-sm text-gray-500 mt-1">@DateTime.Parse(today).ToString("dddd, MMMM d, yyyy")</p>
    </div>
    <div class="flex items-center gap-4">
        <!-- Circular Progress -->
        <div class="relative w-20 h-20">
            <svg class="w-20 h-20 transform -rotate-90" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="45" stroke="#e5e7eb" stroke-width="8" fill="none" />
                <circle cx="50" cy="50" r="45" stroke="#22c55e" stroke-width="8" fill="none"
                        stroke-dasharray="@circumference.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                        stroke-dashoffset="@strokeDashoffset.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                        stroke-linecap="round" />
            </svg>
            <div class="absolute inset-0 flex items-center justify-center">
                <span class="text-lg font-bold text-gray-900">@progressPercent%</span>
            </div>
        </div>
        <div class="text-sm text-gray-600">
            <div><span class="font-semibold text-green-600">@completedCount</span> completed</div>
            <div><span class="font-semibold text-amber-600">@pendingCount</span> pending</div>
            <div class="text-gray-400">@totalCount total</div>
        </div>
    </div>
</div>

<!-- Progress Bar -->
<div class="w-full bg-gray-200 rounded-full h-3 mb-6">
    <div class="bg-green-500 h-3 rounded-full transition-all duration-300" style="width: @(progressPercent)%"></div>
</div>

<!-- Filter Tabs -->
<div class="flex gap-2 mb-6">
    <a href="/DailyChecks?filter=all"
       class="px-4 py-2 rounded-lg text-sm font-medium transition-colors @(filter == "all" ? "bg-blue-600 text-white" : "bg-white text-gray-600 hover:bg-gray-100 border border-gray-200")">
        All <span class="ml-1 px-1.5 py-0.5 rounded-full text-xs @(filter == "all" ? "bg-blue-500" : "bg-gray-100")">@totalCount</span>
    </a>
    <a href="/DailyChecks?filter=pending"
       class="px-4 py-2 rounded-lg text-sm font-medium transition-colors @(filter == "pending" ? "bg-amber-500 text-white" : "bg-white text-gray-600 hover:bg-gray-100 border border-gray-200")">
        Pending <span class="ml-1 px-1.5 py-0.5 rounded-full text-xs @(filter == "pending" ? "bg-amber-400" : "bg-gray-100")">@pendingCount</span>
    </a>
    <a href="/DailyChecks?filter=completed"
       class="px-4 py-2 rounded-lg text-sm font-medium transition-colors @(filter == "completed" ? "bg-green-600 text-white" : "bg-white text-gray-600 hover:bg-gray-100 border border-gray-200")">
        Completed <span class="ml-1 px-1.5 py-0.5 rounded-full text-xs @(filter == "completed" ? "bg-green-500" : "bg-gray-100")">@completedCount</span>
    </a>
</div>

@if (totalCount == 0)
{
    <!-- Seed Button -->
    <div class="bg-white rounded-xl border border-gray-200 p-8 text-center">
        <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
        </svg>
        <h3 class="text-lg font-semibold text-gray-700 mb-2">No checks for today</h3>
        <p class="text-gray-500 mb-4">Start by loading the default inspection checklist or add custom items.</p>
        <form method="post" action="/DailyChecks/SeedDefaults">
            @Html.AntiForgeryToken()
            <button type="submit" class="bg-blue-600 text-white px-6 py-2.5 rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors">
                Load 27 Default Checks
            </button>
        </form>
    </div>
}

<!-- Add Custom Check Form -->
<div class="bg-white rounded-xl border border-gray-200 p-4 mb-6">
    <form method="post" action="/DailyChecks/Create" class="flex flex-col sm:flex-row gap-3">
        @Html.AntiForgeryToken()
        <input type="text" name="checkItem" required placeholder="Enter check item..."
               class="flex-1 px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
        <select name="category" class="px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
            @foreach (var cat in categories)
            {
                <option value="@cat">@(char.ToUpper(cat[0]) + cat.Substring(1))</option>
            }
        </select>
        <button type="submit" class="bg-blue-600 text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors whitespace-nowrap">
            Add Check
        </button>
    </form>
</div>

<!-- Checks Grouped by Category -->
@foreach (var group in grouped)
{
    var cat = group.Key;
    var color = CategoryColor(cat);
    var icon = CategoryIcon(cat);
    var catChecks = group.ToList();
    var catCompleted = catChecks.Count(c => c.IsCompleted);
    var catTotal = catChecks.Count;
    var catPercent = catTotal > 0 ? (int)Math.Round((double)catCompleted / catTotal * 100) : 0;

    <details class="bg-white rounded-xl border border-gray-200 mb-4 group" open>
        <summary class="flex items-center justify-between p-4 cursor-pointer select-none hover:bg-gray-50 rounded-xl transition-colors">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-@(color)-100 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-@(color)-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="@icon" />
                    </svg>
                </div>
                <div>
                    <span class="font-semibold text-gray-900 capitalize">@cat</span>
                    <span class="text-xs text-gray-400 ml-2">@catCompleted / @catTotal</span>
                </div>
            </div>
            <div class="flex items-center gap-3">
                <div class="w-32 bg-gray-200 rounded-full h-2 hidden sm:block">
                    <div class="bg-@(color)-500 h-2 rounded-full transition-all" style="width: @(catPercent)%"></div>
                </div>
                <span class="text-sm font-medium text-@(color)-600">@catPercent%</span>
                <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
            </div>
        </summary>

        <div class="border-t border-gray-100 divide-y divide-gray-50">
            @foreach (var check in catChecks)
            {
                <div class="p-4 hover:bg-gray-50 transition-colors @(check.IsCompleted ? "opacity-60" : "")">
                    <div class="flex items-start gap-3">
                        <!-- Toggle Checkbox -->
                        <form method="post" action="/DailyChecks/Toggle" class="flex-shrink-0 mt-0.5">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@check.Id" />
                            <input type="hidden" name="completedBy" value="" />
                            <button type="submit" class="w-5 h-5 rounded border-2 flex items-center justify-center transition-colors
                                @(check.IsCompleted ? "bg-green-500 border-green-500" : "border-gray-300 hover:border-green-400")">
                                @if (check.IsCompleted)
                                {
                                    <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                                    </svg>
                                }
                            </button>
                        </form>

                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2 flex-wrap">
                                <span class="text-sm font-medium @(check.IsCompleted ? "line-through text-gray-400" : "text-gray-900")">
                                    @check.CheckItem
                                </span>
                                <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full bg-@(color)-100 text-@(color)-700 capitalize">
                                    @cat
                                </span>
                            </div>

                            @if (check.IsCompleted && !string.IsNullOrEmpty(check.CompletedBy))
                            {
                                <p class="text-xs text-gray-400 mt-1">Completed by @check.CompletedBy</p>
                            }

                            @if (!string.IsNullOrEmpty(check.Notes))
                            {
                                <div class="mt-2 bg-amber-50 border border-amber-100 rounded-lg px-3 py-2 text-xs text-amber-800">
                                    @check.Notes
                                </div>
                            }

                            <!-- Add Note Form -->
                            <details class="mt-2">
                                <summary class="text-xs text-blue-600 hover:text-blue-700 cursor-pointer">
                                    @(string.IsNullOrEmpty(check.Notes) ? "Add note" : "Edit note")
                                </summary>
                                <form method="post" action="/DailyChecks/AddNote" class="flex gap-2 mt-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@check.Id" />
                                    <input type="text" name="notes" value="@check.Notes" placeholder="Add a note..."
                                           class="flex-1 px-3 py-1.5 border border-gray-200 rounded-lg text-xs focus:ring-2 focus:ring-blue-500 outline-none" />
                                    <button type="submit" class="bg-blue-600 text-white px-3 py-1.5 rounded-lg text-xs font-medium hover:bg-blue-700">
                                        Save
                                    </button>
                                </form>
                            </details>
                        </div>

                        <!-- Delete -->
                        <form method="post" action="/DailyChecks/Delete" class="flex-shrink-0">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@check.Id" />
                            <button type="submit" onclick="return confirm('Delete this check?')"
                                    class="text-gray-300 hover:text-red-500 transition-colors p-1">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                </svg>
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </details>
}

@if (totalCount > 0 && checks.Count == 0)
{
    <div class="bg-white rounded-xl border border-gray-200 p-8 text-center">
        <p class="text-gray-500">No @filter checks found.</p>
    </div>
}
