@{
    ViewData["Title"] = "Pass Logs";

    var passLogs = ViewBag.PassLogs as List<PassLog> ?? new List<PassLog>();
    var grouped = ViewBag.GroupedPassLogs as Dictionary<string, List<PassLog>> ?? new Dictionary<string, List<PassLog>>();
    var selectedDate = ViewBag.SelectedDate as string ?? DateTime.Today.ToString("yyyy-MM-dd");
    var unreadCount = (int)(ViewBag.UnreadCount ?? 0);
    var totalCount = (int)(ViewBag.TotalCount ?? 0);

    var shifts = new[] { "AM", "PM", "Night" };

    var shiftTransitions = new[] {
        new { From = "AM", To = "PM", Label = "AM \u2192 PM", Key = "AM-PM" },
        new { From = "PM", To = "Night", Label = "PM \u2192 Night", Key = "PM-Night" },
        new { From = "Night", To = "AM", Label = "Night \u2192 AM", Key = "Night-AM" }
    };

    var priorityColors = new Dictionary<string, string> {
        { "low", "gray" },
        { "normal", "blue" },
        { "high", "orange" },
        { "urgent", "red" }
    };

    string GetPriorityColor(string priority)
    {
        return priorityColors.ContainsKey(priority) ? priorityColors[priority] : "gray";
    }

    string Capitalize(string s)
    {
        return string.IsNullOrEmpty(s) ? s : char.ToUpper(s[0]) + s.Substring(1);
    }
}

<!-- Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Pass Logs</h1>
        <p class="text-sm text-gray-500 mt-1">Shift-to-shift communication and handoff notes</p>
    </div>
    <div class="flex items-center gap-3">
        <span class="bg-amber-100 text-amber-700 px-3 py-1 rounded-full text-sm font-medium">
            @unreadCount unread
        </span>
        <span class="bg-gray-100 text-gray-600 px-3 py-1 rounded-full text-sm font-medium">
            @totalCount total
        </span>
    </div>
</div>

<!-- Create Form -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">New Pass Log</h2>
    <form asp-controller="PassLogs" asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Shift From</label>
                <select name="shiftFrom" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                    @foreach (var shift in shifts)
                    {
                        <option value="@shift">@shift</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Shift To</label>
                <select name="shiftTo" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                    <option value="PM">PM</option>
                    <option value="Night">Night</option>
                    <option value="AM">AM</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Priority</label>
                <select name="priority" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                    <option value="low">Low</option>
                    <option value="normal" selected>Normal</option>
                    <option value="high">High</option>
                    <option value="urgent">Urgent</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Your Name</label>
                <input type="text" name="createdBy" required placeholder="Enter your name"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
            </div>
        </div>
        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Message</label>
            <textarea name="message" required rows="3" placeholder="Describe what the incoming shift needs to know..."
                      class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none resize-none"></textarea>
        </div>
        <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-lg text-sm font-medium transition-colors">
            Add Pass Log
        </button>
    </form>
</div>

<!-- Date Filter -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-6">
    <form method="get" asp-controller="PassLogs" asp-action="Index" class="flex items-center gap-2">
        <label class="text-sm font-medium text-gray-700">Date:</label>
        <input type="date" name="date" value="@selectedDate"
               onchange="this.form.submit()"
               class="border border-gray-300 rounded-lg px-3 py-1.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
    </form>
</div>

<!-- Pass Log Entries Grouped by Shift Transition -->
@if (passLogs.Count == 0)
{
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-12 text-center">
        <div class="text-gray-400 text-4xl mb-3">&#128196;</div>
        <p class="text-gray-500 text-sm">No pass log entries found for this date.</p>
    </div>
}
else
{
    @foreach (var transition in shiftTransitions)
    {
        var hasEntries = grouped.ContainsKey(transition.Key);
        var entries = hasEntries ? grouped[transition.Key] : new List<PassLog>();

        if (!hasEntries) continue;

        <div class="mb-6">
            <div class="flex items-center gap-3 mb-3">
                <h3 class="text-lg font-semibold text-gray-900">@transition.Label</h3>
                <span class="bg-blue-100 text-blue-700 px-2.5 py-0.5 rounded-full text-xs font-medium">
                    @entries.Count @(entries.Count == 1 ? "entry" : "entries")
                </span>
                @{
                    var sectionUnread = entries.Count(e => !e.IsRead);
                }
                @if (sectionUnread > 0)
                {
                    <span class="bg-amber-100 text-amber-700 px-2.5 py-0.5 rounded-full text-xs font-medium">
                        @sectionUnread unread
                    </span>
                }
            </div>

            <div class="space-y-3">
                @foreach (var entry in entries)
                {
                    var pColor = GetPriorityColor(entry.Priority);
                    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 @(!entry.IsRead ? "border-l-4 border-l-amber-400" : "")">
                        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
                            <div class="flex-1">
                                <div class="flex flex-wrap items-center gap-2 mb-2">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-@(pColor)-100 text-@(pColor)-700">
                                        @Capitalize(entry.Priority)
                                    </span>
                                    <span class="text-xs text-gray-400">
                                        @entry.CreatedAt.ToLocalTime().ToString("h:mm tt")
                                    </span>
                                    @if (entry.IsRead)
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">
                                            Read
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">
                                            Unread
                                        </span>
                                    }
                                </div>
                                <p class="text-sm text-gray-800 mb-2">@entry.Message</p>
                                <div class="flex flex-wrap items-center gap-3 text-xs text-gray-400">
                                    <span>By: <span class="font-medium text-gray-600">@entry.CreatedBy</span></span>
                                    @if (entry.IsRead && entry.ReadBy != null)
                                    {
                                        <span>Read by: <span class="font-medium text-gray-600">@entry.ReadBy</span> at @entry.ReadAt?.ToLocalTime().ToString("h:mm tt")</span>
                                    }
                                </div>
                            </div>

                            <div class="flex items-center gap-2 shrink-0">
                                @if (!entry.IsRead)
                                {
                                    <form asp-controller="PassLogs" asp-action="MarkAsRead" method="post" class="flex items-center gap-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@entry.Id" />
                                        <input type="text" name="readBy" required placeholder="Your name"
                                               class="border border-gray-300 rounded-lg px-2 py-1 text-xs w-28 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
                                        <button type="submit" class="bg-green-600 hover:bg-green-700 text-white px-3 py-1 rounded-lg text-xs font-medium transition-colors">
                                            Mark Read
                                        </button>
                                    </form>
                                }

                                <form asp-controller="PassLogs" asp-action="Delete" method="post"
                                      onsubmit="return confirm('Are you sure you want to delete this pass log?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@entry.Id" />
                                    <button type="submit" class="bg-red-50 hover:bg-red-100 text-red-600 px-3 py-1 rounded-lg text-xs font-medium transition-colors">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @* Show any entries with non-standard shift transitions *@
    var standardKeys = shiftTransitions.Select(t => t.Key).ToHashSet();
    var otherGroups = grouped.Where(g => !standardKeys.Contains(g.Key)).ToList();
    @foreach (var group in otherGroups)
    {
        var parts = group.Key.Split('-');
        var fromShift = parts.Length > 0 ? parts[0] : "?";
        var toShift = parts.Length > 1 ? parts[1] : "?";

        <div class="mb-6">
            <div class="flex items-center gap-3 mb-3">
                <h3 class="text-lg font-semibold text-gray-900">@fromShift &#8594; @toShift</h3>
                <span class="bg-blue-100 text-blue-700 px-2.5 py-0.5 rounded-full text-xs font-medium">
                    @group.Value.Count @(group.Value.Count == 1 ? "entry" : "entries")
                </span>
            </div>

            <div class="space-y-3">
                @foreach (var entry in group.Value)
                {
                    var pColor = GetPriorityColor(entry.Priority);
                    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 @(!entry.IsRead ? "border-l-4 border-l-amber-400" : "")">
                        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
                            <div class="flex-1">
                                <div class="flex flex-wrap items-center gap-2 mb-2">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-@(pColor)-100 text-@(pColor)-700">
                                        @Capitalize(entry.Priority)
                                    </span>
                                    <span class="text-xs text-gray-400">
                                        @entry.CreatedAt.ToLocalTime().ToString("h:mm tt")
                                    </span>
                                    @if (entry.IsRead)
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">
                                            Read
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">
                                            Unread
                                        </span>
                                    }
                                </div>
                                <p class="text-sm text-gray-800 mb-2">@entry.Message</p>
                                <div class="flex flex-wrap items-center gap-3 text-xs text-gray-400">
                                    <span>By: <span class="font-medium text-gray-600">@entry.CreatedBy</span></span>
                                    @if (entry.IsRead && entry.ReadBy != null)
                                    {
                                        <span>Read by: <span class="font-medium text-gray-600">@entry.ReadBy</span> at @entry.ReadAt?.ToLocalTime().ToString("h:mm tt")</span>
                                    }
                                </div>
                            </div>

                            <div class="flex items-center gap-2 shrink-0">
                                @if (!entry.IsRead)
                                {
                                    <form asp-controller="PassLogs" asp-action="MarkAsRead" method="post" class="flex items-center gap-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@entry.Id" />
                                        <input type="text" name="readBy" required placeholder="Your name"
                                               class="border border-gray-300 rounded-lg px-2 py-1 text-xs w-28 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
                                        <button type="submit" class="bg-green-600 hover:bg-green-700 text-white px-3 py-1 rounded-lg text-xs font-medium transition-colors">
                                            Mark Read
                                        </button>
                                    </form>
                                }

                                <form asp-controller="PassLogs" asp-action="Delete" method="post"
                                      onsubmit="return confirm('Are you sure you want to delete this pass log?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@entry.Id" />
                                    <button type="submit" class="bg-red-50 hover:bg-red-100 text-red-600 px-3 py-1 rounded-lg text-xs font-medium transition-colors">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
}
