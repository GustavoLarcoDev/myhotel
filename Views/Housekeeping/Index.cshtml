@{
    ViewData["Title"] = "Housekeeping";
    var totalRooms = ViewBag.TotalRooms as int? ?? 0;
    var roomsNeedingCleaning = ViewBag.RoomsNeedingCleaning as int? ?? 0;
    var pendingRequests = ViewBag.PendingRequests as int? ?? 0;
    var completedToday = ViewBag.CompletedToday as int? ?? 0;
}

<div class="space-y-8">
    <!-- Header -->
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Housekeeping</h1>
        <p class="text-sm text-gray-500 mt-1">Department overview and quick navigation</p>
    </div>

    <!-- Stat Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Rooms Needing Cleaning -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 bg-yellow-50 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                    </svg>
                </div>
                @if (roomsNeedingCleaning > 0)
                {
                    <span class="text-xs font-medium bg-yellow-100 text-yellow-700 px-2 py-0.5 rounded-full">Dirty</span>
                }
            </div>
            <p class="text-2xl font-bold text-gray-900">@roomsNeedingCleaning</p>
            <p class="text-xs text-gray-500 mt-1">Rooms Needing Cleaning</p>
        </div>

        <!-- Pending Requests -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 bg-orange-50 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                @if (pendingRequests > 0)
                {
                    <span class="text-xs font-medium bg-orange-100 text-orange-700 px-2 py-0.5 rounded-full">Active</span>
                }
            </div>
            <p class="text-2xl font-bold text-gray-900">@pendingRequests</p>
            <p class="text-xs text-gray-500 mt-1">Pending Requests</p>
        </div>

        <!-- Completed Today -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 bg-green-50 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
            </div>
            <p class="text-2xl font-bold text-gray-900">@completedToday</p>
            <p class="text-xs text-gray-500 mt-1">Completed Today</p>
        </div>

        <!-- Total Rooms -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                    </svg>
                </div>
            </div>
            <p class="text-2xl font-bold text-gray-900">@totalRooms</p>
            <p class="text-xs text-gray-500 mt-1">Total Rooms</p>
        </div>
    </div>

    <!-- Quick Navigation -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Quick Navigation</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
            <a href="/Rooms" class="flex flex-col items-center gap-2 p-5 bg-gray-50 rounded-xl hover:bg-blue-50 hover:text-blue-700 transition-colors text-gray-700">
                <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                </svg>
                <span class="text-xs font-medium">Rooms</span>
            </a>

            <a href="/Housekeeping/CleaningRequests" class="flex flex-col items-center gap-2 p-5 bg-gray-50 rounded-xl hover:bg-yellow-50 hover:text-yellow-700 transition-colors text-gray-700">
                <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
                <span class="text-xs font-medium">Cleaning Requests</span>
            </a>

            <a href="/DailyChecks" class="flex flex-col items-center gap-2 p-5 bg-gray-50 rounded-xl hover:bg-green-50 hover:text-green-700 transition-colors text-gray-700">
                <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                </svg>
                <span class="text-xs font-medium">Daily Checks</span>
            </a>

            <a href="/Housekeeping/Staff" class="flex flex-col items-center gap-2 p-5 bg-gray-50 rounded-xl hover:bg-purple-50 hover:text-purple-700 transition-colors text-gray-700">
                <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                </svg>
                <span class="text-xs font-medium">Staff</span>
            </a>

            <a href="/Meetings" class="flex flex-col items-center gap-2 p-5 bg-gray-50 rounded-xl hover:bg-indigo-50 hover:text-indigo-700 transition-colors text-gray-700">
                <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <span class="text-xs font-medium">Meetings</span>
            </a>

            <a href="/Messaging" class="flex flex-col items-center gap-2 p-5 bg-gray-50 rounded-xl hover:bg-pink-50 hover:text-pink-700 transition-colors text-gray-700">
                <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                <span class="text-xs font-medium">Messages</span>
            </a>

            <a href="/Scheduling" class="flex flex-col items-center gap-2 p-5 bg-gray-50 rounded-xl hover:bg-teal-50 hover:text-teal-700 transition-colors text-gray-700">
                <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-xs font-medium">Schedule</span>
            </a>

            <a href="/Inventory" class="flex flex-col items-center gap-2 p-5 bg-gray-50 rounded-xl hover:bg-amber-50 hover:text-amber-700 transition-colors text-gray-700">
                <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                </svg>
                <span class="text-xs font-medium">Inventory</span>
            </a>
        </div>
    </div>
</div>
