@model CleaningRequest
@{
    ViewData["Title"] = "Edit Cleaning Request";
    var rooms = ViewBag.Rooms as List<Room> ?? new List<Room>();
    var hkStaff = ViewBag.HkStaff as IEnumerable<dynamic> ?? new List<dynamic>();
    var requesterName = ViewBag.RequesterName as string ?? "Unknown";
}

<!-- Header -->
<div class="mb-6">
    <div class="flex items-center gap-2 mb-1">
        <a href="/Housekeeping/CleaningRequests" class="text-gray-400 hover:text-gray-600 transition-colors">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </a>
        <h1 class="text-2xl font-bold text-gray-900">Edit Cleaning Request #@Model.Id</h1>
    </div>
    <div class="flex items-center gap-3 mt-2">
        <span class="text-sm text-gray-500">Requested by <span class="font-medium text-gray-700">@requesterName</span></span>
        <span class="text-sm text-gray-400">@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
        @if (Model.CompletedAt != null)
        {
            <span class="text-sm text-green-600">Completed @Model.CompletedAt.Value.ToString("MMM dd, yyyy HH:mm")</span>
        }
    </div>
</div>

<!-- Form -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 max-w-2xl">
    <form method="post" asp-action="EditCleaningRequest">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />
        <div class="space-y-5">
            <!-- Room (read-only) -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Room</label>
                <div class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-700">
                    @if (Model.Room != null)
                    {
                        <span>@Model.Room.Number (Floor @Model.Room.Floor - @Model.Room.Type)</span>
                    }
                    else
                    {
                        <span class="text-gray-400">No specific room</span>
                    }
                </div>
            </div>

            <!-- Request Type -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Request Type</label>
                @{
                    var requestTypes = new[] {
                        ("standard", "Standard"),
                        ("deep", "Deep Clean"),
                        ("turnover", "Turnover"),
                        ("rush", "Rush"),
                        ("inspection", "Inspection")
                    };
                }
                <select name="requestType" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none">
                    @foreach (var (val, label) in requestTypes)
                    {
                        if (Model.RequestType == val)
                        {
                            <option value="@val" selected="selected">@label</option>
                        }
                        else
                        {
                            <option value="@val">@label</option>
                        }
                    }
                </select>
            </div>

            <!-- Priority -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Priority</label>
                @{
                    var priorities = new[] {
                        ("low", "Low"),
                        ("normal", "Normal"),
                        ("high", "High"),
                        ("urgent", "Urgent")
                    };
                }
                <select name="priority" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none">
                    @foreach (var (val, label) in priorities)
                    {
                        if (Model.Priority == val)
                        {
                            <option value="@val" selected="selected">@label</option>
                        }
                        else
                        {
                            <option value="@val">@label</option>
                        }
                    }
                </select>
            </div>

            <!-- Status -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                @{
                    var statusOptions = new[] {
                        ("pending", "Pending"),
                        ("in_progress", "In Progress"),
                        ("completed", "Completed"),
                        ("cancelled", "Cancelled")
                    };
                }
                <select name="status" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none">
                    @foreach (var (val, label) in statusOptions)
                    {
                        if (Model.Status == val)
                        {
                            <option value="@val" selected="selected">@label</option>
                        }
                        else
                        {
                            <option value="@val">@label</option>
                        }
                    }
                </select>
            </div>

            <!-- Assigned To -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Assigned To</label>
                <select name="assignedTo" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none">
                    <option value="">-- Unassigned --</option>
                    @foreach (var staff in hkStaff)
                    {
                        if ((string)staff.Id == Model.AssignedTo)
                        {
                            <option value="@staff.Id" selected="selected">@staff.FirstName @staff.LastName</option>
                        }
                        else
                        {
                            <option value="@staff.Id">@staff.FirstName @staff.LastName</option>
                        }
                    }
                </select>
            </div>

            <!-- Notes -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Notes</label>
                <textarea name="notes" rows="4" placeholder="Any special instructions or details..." class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none resize-none">@Model.Notes</textarea>
            </div>

            <!-- Actions -->
            <div class="flex items-center gap-3 pt-2">
                <button type="submit" class="px-6 py-2.5 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors">Save Changes</button>
                <a href="/Housekeeping/CleaningRequests" class="px-6 py-2.5 bg-gray-100 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-200 transition-colors">Cancel</a>
            </div>
        </div>
    </form>
</div>
