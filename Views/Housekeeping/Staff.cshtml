@{
    ViewData["Title"] = "Housekeeping Staff";
    var staffList = ViewBag.StaffList as IEnumerable<dynamic> ?? new List<dynamic>();
    var activeRequestCounts = ViewBag.ActiveRequestCounts as Dictionary<string, int> ?? new Dictionary<string, int>();
    var completedTodayCounts = ViewBag.CompletedTodayCounts as Dictionary<string, int> ?? new Dictionary<string, int>();
    var departmentName = ViewBag.DepartmentName as string ?? "Housekeeping";
}

<!-- Header -->
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div>
        <div class="flex items-center gap-2 mb-1">
            <a href="/Housekeeping" class="text-gray-400 hover:text-gray-600 transition-colors">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            </a>
            <h1 class="text-2xl font-bold text-gray-900">@departmentName Staff</h1>
        </div>
        <p class="text-sm text-gray-500">Team members and their current workload</p>
    </div>
</div>

@if (!staffList.Any())
{
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-12 text-center">
        <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
        </svg>
        <p class="text-gray-400 text-sm mb-1">No staff members found in the Housekeeping department.</p>
        <p class="text-gray-400 text-xs">Assign users to the Housekeeping department in the Admin panel.</p>
    </div>
}
else
{
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        @foreach (var staff in staffList)
        {
            var fullName = $"{staff.FirstName} {staff.LastName}";
            var initials = $"{((string)staff.FirstName).Substring(0, 1)}{((string)staff.LastName).Substring(0, 1)}";
            var activeCount = activeRequestCounts.ContainsKey((string)staff.Id) ? activeRequestCounts[(string)staff.Id] : 0;
            var completedCount = completedTodayCounts.ContainsKey((string)staff.Id) ? completedTodayCounts[(string)staff.Id] : 0;
            var isActive = (bool)staff.IsActive;
            var isManager = (bool)staff.IsManager;

            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
                <div class="flex items-start gap-4">
                    <!-- Avatar -->
                    <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center shrink-0">
                        <span class="text-sm font-bold text-blue-700">@initials</span>
                    </div>

                    <!-- Info -->
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 flex-wrap">
                            <h3 class="text-sm font-semibold text-gray-900 truncate">@fullName</h3>
                            @if (isManager)
                            {
                                <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-purple-100 text-purple-700">Manager</span>
                            }
                            @if (!isActive)
                            {
                                <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-red-100 text-red-700">Inactive</span>
                            }
                        </div>

                        @if (staff.Email != null)
                        {
                            <p class="text-xs text-gray-500 truncate mt-0.5">@staff.Email</p>
                        }
                        @if (staff.Phone != null)
                        {
                            <p class="text-xs text-gray-400 mt-0.5">@staff.Phone</p>
                        }

                        <!-- Workload -->
                        <div class="flex items-center gap-3 mt-3">
                            <div class="flex items-center gap-1">
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium @(activeCount > 0 ? "bg-yellow-100 text-yellow-700" : "bg-gray-100 text-gray-500")">
                                    @activeCount active
                                </span>
                            </div>
                            <div class="flex items-center gap-1">
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">
                                    @completedCount done today
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
