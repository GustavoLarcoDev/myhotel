@model List<CleaningRequest>
@{
    ViewData["Title"] = "Cleaning Requests";
    var currentStatus = (string)ViewBag.CurrentStatus;
    var totalCount = (int)ViewBag.TotalCount;
    var pendingCount = (int)ViewBag.PendingCount;
    var inProgressCount = (int)ViewBag.InProgressCount;
    var completedCount = (int)ViewBag.CompletedCount;
    var cancelledCount = (int)ViewBag.CancelledCount;
    var userNames = (Dictionary<string, string>)ViewBag.UserNames;
}

<!-- Header -->
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Cleaning Requests</h1>
        <div class="flex items-center gap-3 mt-2 flex-wrap">
            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700">Total: @totalCount</span>
            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-700">Pending: @pendingCount</span>
            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700">In Progress: @inProgressCount</span>
            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Completed: @completedCount</span>
            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">Cancelled: @cancelledCount</span>
        </div>
    </div>
    <a href="/Housekeeping/CreateCleaningRequest" class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors whitespace-nowrap">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        New Request
    </a>
</div>

<!-- Status Filter Tabs -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-6">
    <div class="flex items-center gap-1 flex-wrap">
        @{
            var statuses = new[] {
                ("all", "All", totalCount),
                ("pending", "Pending", pendingCount),
                ("in_progress", "In Progress", inProgressCount),
                ("completed", "Completed", completedCount),
                ("cancelled", "Cancelled", cancelledCount)
            };
        }
        @foreach (var (val, label, count) in statuses)
        {
            var isActive = currentStatus == val;
            <a href="@Url.Action("CleaningRequests", new { status = val })"
               class="px-3 py-1.5 rounded-lg text-sm font-medium transition-colors @(isActive ? "bg-blue-100 text-blue-700" : "text-gray-500 hover:text-gray-700 hover:bg-gray-50")">
                @label <span class="ml-1 text-xs">@count</span>
            </a>
        }
    </div>
</div>

<!-- Request Cards -->
@if (!Model.Any())
{
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-12 text-center">
        <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        <p class="text-gray-400 text-sm">No cleaning requests found.</p>
        <a href="/Housekeeping/CreateCleaningRequest" class="inline-flex items-center gap-1 mt-3 text-sm text-blue-600 hover:text-blue-700 font-medium">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Create one
        </a>
    </div>
}
else
{
    <div class="space-y-4">
        @foreach (var req in Model)
        {
            var priorityClass = req.Priority switch
            {
                "low" => "bg-gray-100 text-gray-600",
                "high" => "bg-orange-100 text-orange-700",
                "urgent" => "bg-red-100 text-red-700",
                _ => "bg-blue-100 text-blue-700"
            };
            var statusClass = req.Status switch
            {
                "pending" => "bg-yellow-100 text-yellow-700",
                "in_progress" => "bg-blue-100 text-blue-700",
                "completed" => "bg-green-100 text-green-700",
                "cancelled" => "bg-red-100 text-red-700",
                _ => "bg-gray-100 text-gray-600"
            };
            var statusLabel = req.Status switch
            {
                "pending" => "Pending",
                "in_progress" => "In Progress",
                "completed" => "Completed",
                "cancelled" => "Cancelled",
                _ => req.Status
            };
            var typeClass = req.RequestType switch
            {
                "deep" => "bg-purple-100 text-purple-700",
                "turnover" => "bg-teal-100 text-teal-700",
                "rush" => "bg-red-100 text-red-700",
                "inspection" => "bg-indigo-100 text-indigo-700",
                _ => "bg-gray-100 text-gray-600"
            };

            var assignedName = !string.IsNullOrEmpty(req.AssignedTo) && userNames.ContainsKey(req.AssignedTo)
                ? userNames[req.AssignedTo]
                : null;
            var requesterName = !string.IsNullOrEmpty(req.RequestedBy) && userNames.ContainsKey(req.RequestedBy)
                ? userNames[req.RequestedBy]
                : null;

            <a href="/Housekeeping/EditCleaningRequest/@req.Id" class="block bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
                <div class="flex flex-col lg:flex-row lg:items-center gap-3">
                    <!-- Room -->
                    <div class="flex items-center gap-3 lg:w-28 shrink-0">
                        @if (req.Room != null)
                        {
                            <span class="inline-flex items-center px-2.5 py-1 rounded text-sm font-bold bg-gray-800 text-white">@req.Room.Number</span>
                        }
                        else
                        {
                            <span class="inline-flex items-center px-2.5 py-1 rounded text-sm font-medium bg-gray-100 text-gray-500">N/A</span>
                        }
                    </div>

                    <!-- Badges -->
                    <div class="flex items-center gap-2 flex-wrap flex-1">
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium @typeClass">@req.RequestType</span>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium @priorityClass">@req.Priority</span>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium @statusClass">@statusLabel</span>
                    </div>

                    <!-- Assigned To -->
                    <div class="lg:w-40 shrink-0">
                        @if (assignedName != null)
                        {
                            <div class="flex items-center gap-1.5">
                                <div class="w-6 h-6 bg-blue-100 rounded-full flex items-center justify-center">
                                    <span class="text-xs font-medium text-blue-700">@assignedName[0]</span>
                                </div>
                                <span class="text-sm text-gray-700 truncate">@assignedName</span>
                            </div>
                        }
                        else
                        {
                            <span class="text-xs text-gray-400">Unassigned</span>
                        }
                    </div>

                    <!-- Time -->
                    <div class="lg:w-44 shrink-0 text-right">
                        <p class="text-xs text-gray-400">@req.CreatedAt.ToString("MMM dd, yyyy HH:mm")</p>
                        @if (req.CompletedAt != null)
                        {
                            <p class="text-xs text-green-600 mt-0.5">Completed @req.CompletedAt.Value.ToString("MMM dd, HH:mm")</p>
                        }
                        @if (requesterName != null)
                        {
                            <p class="text-xs text-gray-400 mt-0.5">by @requesterName</p>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(req.Notes))
                {
                    <div class="mt-3 p-3 bg-gray-50 rounded-lg">
                        <p class="text-xs text-gray-600 line-clamp-2">@req.Notes</p>
                    </div>
                }
            </a>
        }
    </div>
}
