@model List<Room>
@{
    ViewData["Title"] = "Rooms";
    var allRooms = (List<Room>)ViewBag.AllRooms;
    var floors = (List<int>)ViewBag.Floors;
    var currentFloor = (string)ViewBag.CurrentFloor;
    var currentStatus = (string)ViewBag.CurrentStatus;
    var totalCount = (int)ViewBag.TotalCount;
    var vacantCleanCount = (int)ViewBag.VacantCleanCount;
    var vacantDirtyCount = (int)ViewBag.VacantDirtyCount;
    var occupiedCount = (int)ViewBag.OccupiedCount;
    var outOfOrderCount = (int)ViewBag.OutOfOrderCount;
    var inspectedCount = (int)ViewBag.InspectedCount;
}

<!-- Header -->
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Rooms</h1>
        <div class="flex items-center gap-2 mt-2 flex-wrap">
            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700">Total: @totalCount</span>
            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Clean: @vacantCleanCount</span>
            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-700">Dirty: @vacantDirtyCount</span>
            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700">Occupied: @occupiedCount</span>
            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">OOO: @outOfOrderCount</span>
            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-700">Inspected: @inspectedCount</span>
        </div>
    </div>
</div>

<!-- Create Form -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-6">
    <h2 class="text-sm font-semibold text-gray-700 mb-4">Add Room</h2>
    <form method="post" asp-action="Create">
        @Html.AntiForgeryToken()
        <div class="flex flex-col sm:flex-row items-end gap-4">
            <div>
                <label class="block text-xs font-medium text-gray-500 mb-1">Room Number *</label>
                <input type="text" name="number" required placeholder="e.g. 101" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none" />
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-500 mb-1">Floor</label>
                <input type="number" name="floor" value="1" min="0" max="99" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none" />
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-500 mb-1">Type</label>
                <select name="type" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none">
                    <option value="standard">Standard</option>
                    <option value="deluxe">Deluxe</option>
                    <option value="suite">Suite</option>
                    <option value="accessible">Accessible</option>
                </select>
            </div>
            <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors whitespace-nowrap">Add Room</button>
        </div>
    </form>
</div>

<!-- Seed Button (if no rooms) -->
@if (totalCount == 0)
{
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8 mb-6 text-center">
        <p class="text-gray-500 text-sm mb-4">No rooms yet. Seed sample rooms to get started.</p>
        <form method="post" asp-action="SeedRooms">
            <button type="submit" class="px-6 py-2.5 bg-green-600 text-white rounded-lg text-sm font-medium hover:bg-green-700 transition-colors">Seed Sample Rooms (Floors 1-4)</button>
        </form>
    </div>
}

<!-- Filters -->
@if (totalCount > 0)
{
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-6">
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <!-- Floor Filter -->
            <div class="flex items-center gap-1 flex-wrap">
                <span class="text-xs font-medium text-gray-500 mr-2">Floor:</span>
                <a href="@Url.Action("Index", new { floor = "all", status = currentStatus })"
                   class="px-2.5 py-1 rounded-lg text-xs font-medium transition-colors @(currentFloor == "all" ? "bg-blue-100 text-blue-700" : "text-gray-500 hover:text-gray-700 hover:bg-gray-50")">All</a>
                @foreach (var f in floors)
                {
                    <a href="@Url.Action("Index", new { floor = f.ToString(), status = currentStatus })"
                       class="px-2.5 py-1 rounded-lg text-xs font-medium transition-colors @(currentFloor == f.ToString() ? "bg-blue-100 text-blue-700" : "text-gray-500 hover:text-gray-700 hover:bg-gray-50")">@f</a>
                }
            </div>

            <!-- Status Filter -->
            <div class="flex items-center gap-1 flex-wrap sm:ml-auto">
                <span class="text-xs font-medium text-gray-500 mr-2">Status:</span>
                @{
                    var statusFilters = new[] {
                        ("all", "All"),
                        ("vacant-clean", "Clean"),
                        ("vacant-dirty", "Dirty"),
                        ("occupied", "Occupied"),
                        ("out-of-order", "OOO"),
                        ("inspected", "Inspected")
                    };
                }
                @foreach (var (val, label) in statusFilters)
                {
                    <a href="@Url.Action("Index", new { floor = currentFloor, status = val })"
                       class="px-2.5 py-1 rounded-lg text-xs font-medium transition-colors @(currentStatus == val ? "bg-blue-100 text-blue-700" : "text-gray-500 hover:text-gray-700 hover:bg-gray-50")">@label</a>
                }
            </div>
        </div>
    </div>
}

<!-- Room Grid Grouped by Floor -->
@if (Model.Any())
{
    var grouped = Model.GroupBy(r => r.Floor).OrderBy(g => g.Key);
    @foreach (var floorGroup in grouped)
    {
        <div class="mb-8">
            <h3 class="text-sm font-semibold text-gray-600 mb-3">Floor @floorGroup.Key</h3>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
                @foreach (var room in floorGroup.OrderBy(r => r.Number))
                {
                    var statusColor = room.Status switch
                    {
                        "vacant-clean" => "border-green-300 bg-green-50",
                        "vacant-dirty" => "border-yellow-300 bg-yellow-50",
                        "occupied" => "border-blue-300 bg-blue-50",
                        "out-of-order" => "border-red-300 bg-red-50",
                        "inspected" => "border-purple-300 bg-purple-50",
                        _ => "border-gray-200 bg-white"
                    };
                    var statusBadge = room.Status switch
                    {
                        "vacant-clean" => "bg-green-100 text-green-700",
                        "vacant-dirty" => "bg-yellow-100 text-yellow-700",
                        "occupied" => "bg-blue-100 text-blue-700",
                        "out-of-order" => "bg-red-100 text-red-700",
                        "inspected" => "bg-purple-100 text-purple-700",
                        _ => "bg-gray-100 text-gray-600"
                    };
                    var statusLabel = room.Status switch
                    {
                        "vacant-clean" => "Clean",
                        "vacant-dirty" => "Dirty",
                        "occupied" => "Occupied",
                        "out-of-order" => "OOO",
                        "inspected" => "Inspected",
                        _ => room.Status
                    };
                    var typeBadge = room.Type switch
                    {
                        "deluxe" => "bg-indigo-100 text-indigo-700",
                        "suite" => "bg-amber-100 text-amber-700",
                        "accessible" => "bg-teal-100 text-teal-700",
                        _ => "bg-gray-100 text-gray-600"
                    };

                    <div class="rounded-xl border-2 @statusColor p-4 relative">
                        <!-- Room Number & Type -->
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-lg font-bold text-gray-900">@room.Number</span>
                            <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium @typeBadge">@room.Type</span>
                        </div>

                        <!-- Status Badge -->
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium @statusBadge mb-2">@statusLabel</span>

                        <!-- Notices -->
                        @if (room.Notices.Any())
                        {
                            <div class="flex flex-wrap gap-1 mb-2">
                                @foreach (var notice in room.Notices)
                                {
                                    var noticeColor = notice.Type switch
                                    {
                                        "VIP" => "bg-amber-200 text-amber-800",
                                        "DND" => "bg-red-200 text-red-800",
                                        "early-check-in" => "bg-blue-200 text-blue-800",
                                        "late-checkout" => "bg-purple-200 text-purple-800",
                                        "connecting" => "bg-teal-200 text-teal-800",
                                        _ => "bg-gray-200 text-gray-700"
                                    };
                                    <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-[10px] font-medium @noticeColor">
                                        @notice.Type
                                        <form method="post" asp-action="RemoveNotice" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@notice.Id" />
                                            <button type="submit" class="hover:text-red-600 ml-0.5">&times;</button>
                                        </form>
                                    </span>
                                }
                            </div>
                        }

                        <!-- Status Cycle -->
                        <form method="post" asp-action="UpdateStatus" class="mb-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@room.Id" />
                            <select name="status" onchange="this.form.submit()" class="w-full px-2 py-1 border border-gray-200 rounded text-xs outline-none bg-white">
                                @{
                                    var roomStatuses = new[] {
                                        ("vacant-clean", "Vacant Clean"),
                                        ("vacant-dirty", "Vacant Dirty"),
                                        ("occupied", "Occupied"),
                                        ("out-of-order", "Out of Order"),
                                        ("inspected", "Inspected")
                                    };
                                }
                                @foreach (var (sVal, sLabel) in roomStatuses)
                                {
                                    if (room.Status == sVal)
                                    {
                                        <option value="@sVal" selected="selected">@sLabel</option>
                                    }
                                    else
                                    {
                                        <option value="@sVal">@sLabel</option>
                                    }
                                }
                            </select>
                        </form>

                        <!-- Add Notice -->
                        <form method="post" asp-action="AddNotice" class="flex gap-1 mb-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="roomId" value="@room.Id" />
                            <select name="type" class="flex-1 px-1 py-1 border border-gray-200 rounded text-xs outline-none bg-white">
                                <option value="early-check-in">Early Check-in</option>
                                <option value="late-checkout">Late Checkout</option>
                                <option value="VIP">VIP</option>
                                <option value="DND">DND</option>
                                <option value="connecting">Connecting</option>
                            </select>
                            <button type="submit" class="px-1.5 py-1 bg-gray-100 hover:bg-gray-200 rounded text-[10px] font-medium text-gray-600 transition-colors">+</button>
                        </form>

                        <!-- Delete -->
                        <form method="post" asp-action="Delete" onsubmit="return swalConfirm(this, 'Delete room @room.Number?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@room.Id" />
                            <button type="submit" class="w-full px-2 py-1 bg-red-50 hover:bg-red-100 text-red-500 rounded text-[10px] font-medium transition-colors">Delete</button>
                        </form>
                    </div>
                }
            </div>
        </div>
    }
}
else if (totalCount > 0)
{
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-12 text-center">
        <p class="text-gray-400 text-sm">No rooms match the current filters.</p>
    </div>
}
