@{
    ViewData["Title"] = "Dashboard";
    var noHotel = ViewBag.NoHotel as bool? ?? false;
}

@if (noHotel)
{
    <div class="flex items-center justify-center min-h-[60vh]">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-12 text-center max-w-md">
            <div class="w-16 h-16 bg-blue-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                </svg>
            </div>
            <h2 class="text-xl font-bold text-gray-900 mb-2">No Hotel Selected</h2>
            <p class="text-gray-500 text-sm">You are not assigned to any hotel yet. Please contact your administrator to be assigned to a property.</p>
        </div>
    </div>
}
else
{
    var openWorkOrders = ViewBag.OpenWorkOrders as int? ?? 0;
    var pendingChecks = ViewBag.PendingChecks as int? ?? 0;
    var totalChecks = ViewBag.TotalChecks as int? ?? 0;
    var completedChecks = ViewBag.CompletedChecks as int? ?? 0;
    var logsToday = ViewBag.LogsToday as int? ?? 0;
    var openComplaints = ViewBag.OpenComplaints as int? ?? 0;
    var unreadMessages = ViewBag.UnreadMessages as int? ?? 0;
    var checkPercent = totalChecks > 0 ? (int)Math.Round((double)completedChecks / totalChecks * 100) : 0;
    var activityFeed = ViewBag.ActivityFeed as dynamic ?? new List<dynamic>();

    <div class="space-y-8">
        <!-- Header -->
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
            <p class="text-sm text-gray-500 mt-1">Today's overview and quick actions</p>
        </div>

        <!-- Summary Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
            <!-- Open Work Orders -->
            <a href="/WorkOrders" class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
                <div class="flex items-center justify-between mb-3">
                    <div class="w-10 h-10 bg-orange-50 rounded-lg flex items-center justify-center">
                        <svg class="w-5 h-5 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    </div>
                    @if (openWorkOrders > 0)
                    {
                        <span class="text-xs font-medium bg-orange-100 text-orange-700 px-2 py-0.5 rounded-full">Open</span>
                    }
                </div>
                <p class="text-2xl font-bold text-gray-900">@openWorkOrders</p>
                <p class="text-xs text-gray-500 mt-1">Work Orders</p>
            </a>

            <!-- Pending Checks -->
            <a href="/DailyChecks" class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
                <div class="flex items-center justify-between mb-3">
                    <div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center">
                        <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
                    </div>
                    @if (pendingChecks > 0)
                    {
                        <span class="text-xs font-medium bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full">Pending</span>
                    }
                </div>
                <p class="text-2xl font-bold text-gray-900">@pendingChecks</p>
                <p class="text-xs text-gray-500 mt-1">Pending Checks</p>
            </a>

            <!-- Logs Today -->
            <a href="/Logs" class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
                <div class="flex items-center justify-between mb-3">
                    <div class="w-10 h-10 bg-green-50 rounded-lg flex items-center justify-center">
                        <svg class="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    </div>
                </div>
                <p class="text-2xl font-bold text-gray-900">@logsToday</p>
                <p class="text-xs text-gray-500 mt-1">Logs Today</p>
            </a>

            <!-- Complaints -->
            <a href="/Complaints" class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
                <div class="flex items-center justify-between mb-3">
                    <div class="w-10 h-10 bg-red-50 rounded-lg flex items-center justify-center">
                        <svg class="w-5 h-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.832c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
                    </div>
                    @if (openComplaints > 0)
                    {
                        <span class="text-xs font-medium bg-red-100 text-red-700 px-2 py-0.5 rounded-full">Open</span>
                    }
                </div>
                <p class="text-2xl font-bold text-gray-900">@openComplaints</p>
                <p class="text-xs text-gray-500 mt-1">Complaints</p>
            </a>

            <!-- Unread Messages -->
            <a href="/Messaging" class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
                <div class="flex items-center justify-between mb-3">
                    <div class="w-10 h-10 bg-purple-50 rounded-lg flex items-center justify-center">
                        <svg class="w-5 h-5 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    </div>
                    @if (unreadMessages > 0)
                    {
                        <span class="text-xs font-medium bg-purple-100 text-purple-700 px-2 py-0.5 rounded-full">New</span>
                    }
                </div>
                <p class="text-2xl font-bold text-gray-900">@unreadMessages</p>
                <p class="text-xs text-gray-500 mt-1">Unread Messages</p>
            </a>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Daily Checks Progress -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <h2 class="text-lg font-semibold text-gray-900 mb-4">Daily Checks Progress</h2>
                <div class="flex items-center justify-center">
                    <div class="relative w-40 h-40">
                        <!-- Background circle -->
                        <svg class="w-full h-full transform -rotate-90" viewBox="0 0 120 120">
                            <circle cx="60" cy="60" r="50" fill="none" stroke="#f3f4f6" stroke-width="10"/>
                            <circle cx="60" cy="60" r="50" fill="none" stroke="#2563eb" stroke-width="10"
                                    stroke-dasharray="@(Math.Round(314.16 * checkPercent / 100.0, 2)) 314.16"
                                    stroke-linecap="round"/>
                        </svg>
                        <!-- Center text -->
                        <div class="absolute inset-0 flex flex-col items-center justify-center">
                            <span class="text-3xl font-bold text-gray-900">@checkPercent%</span>
                            <span class="text-xs text-gray-500">@completedChecks / @totalChecks</span>
                        </div>
                    </div>
                </div>
                <div class="mt-4 text-center">
                    @if (checkPercent == 100 && totalChecks > 0)
                    {
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">All checks completed</span>
                    }
                    else if (totalChecks == 0)
                    {
                        <span class="text-sm text-gray-500">No checks scheduled today</span>
                    }
                    else
                    {
                        <span class="text-sm text-gray-500">@pendingChecks check(s) remaining</span>
                    }
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <h2 class="text-lg font-semibold text-gray-900 mb-4">Quick Actions</h2>
                <div class="grid grid-cols-2 gap-3">
                    <a href="/Logs/Create" class="flex flex-col items-center gap-2 p-4 bg-gray-50 rounded-xl hover:bg-blue-50 hover:text-blue-700 transition-colors text-gray-700">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                        <span class="text-xs font-medium">New Log</span>
                    </a>
                    <a href="/WorkOrders/Create" class="flex flex-col items-center gap-2 p-4 bg-gray-50 rounded-xl hover:bg-orange-50 hover:text-orange-700 transition-colors text-gray-700">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        <span class="text-xs font-medium">Work Order</span>
                    </a>
                    <a href="/Complaints/Create" class="flex flex-col items-center gap-2 p-4 bg-gray-50 rounded-xl hover:bg-red-50 hover:text-red-700 transition-colors text-gray-700">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.832c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
                        <span class="text-xs font-medium">Complaint</span>
                    </a>
                    <a href="/Messaging/Compose" class="flex flex-col items-center gap-2 p-4 bg-gray-50 rounded-xl hover:bg-purple-50 hover:text-purple-700 transition-colors text-gray-700">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                        <span class="text-xs font-medium">Message</span>
                    </a>
                    <a href="/PassLogs/Create" class="flex flex-col items-center gap-2 p-4 bg-gray-50 rounded-xl hover:bg-green-50 hover:text-green-700 transition-colors text-gray-700">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
                        <span class="text-xs font-medium">Pass Log</span>
                    </a>
                    <a href="/DailyChecks" class="flex flex-col items-center gap-2 p-4 bg-gray-50 rounded-xl hover:bg-blue-50 hover:text-blue-700 transition-colors text-gray-700">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
                        <span class="text-xs font-medium">Daily Checks</span>
                    </a>
                </div>
            </div>

            <!-- Recent Activity -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <h2 class="text-lg font-semibold text-gray-900 mb-4">Recent Activity</h2>
                <div class="space-y-3">
                    @if (activityFeed != null && ((IEnumerable<dynamic>)activityFeed).Any())
                    {
                        foreach (var item in (IEnumerable<dynamic>)activityFeed)
                        {
                            var typeColor = (string)item.Type switch
                            {
                                "Work Order" => "bg-orange-100 text-orange-800",
                                "Complaint" => "bg-red-100 text-red-800",
                                "Log" => "bg-green-100 text-green-800",
                                _ => "bg-gray-100 text-gray-800"
                            };
                            var statusColor = "bg-gray-100 text-gray-700";
                            var status = (string)item.Status;
                            if (status == "pending" || status == "open")
                                statusColor = "bg-amber-100 text-amber-800";
                            else if (status == "completed" || status == "resolved" || status == "closed")
                                statusColor = "bg-green-100 text-green-800";
                            else if (status == "in_progress")
                                statusColor = "bg-blue-100 text-blue-800";

                            var timeAgo = "";
                            var diff = DateTime.UtcNow - (DateTime)item.CreatedAt;
                            if (diff.TotalMinutes < 60)
                                timeAgo = $"{(int)diff.TotalMinutes}m ago";
                            else if (diff.TotalHours < 24)
                                timeAgo = $"{(int)diff.TotalHours}h ago";
                            else
                                timeAgo = $"{(int)diff.TotalDays}d ago";

                            var title = (string)item.Title;
                            if (title.Length > 60)
                                title = title.Substring(0, 57) + "...";

                            <div class="flex items-start gap-3 py-2 border-b border-gray-50 last:border-0">
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium @typeColor whitespace-nowrap mt-0.5">@item.Type</span>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm text-gray-900 truncate">@title</p>
                                    <div class="flex items-center gap-2 mt-1">
                                        <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium @statusColor">@status</span>
                                        <span class="text-xs text-gray-400">@timeAgo</span>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-8">
                            <svg class="w-10 h-10 text-gray-300 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
                            <p class="text-sm text-gray-500">No recent activity</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}
