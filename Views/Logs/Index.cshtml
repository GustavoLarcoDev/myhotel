@{
    ViewData["Title"] = "Log Book";

    var logs = ViewBag.Logs as List<Log> ?? new List<Log>();
    var selectedCategory = ViewBag.SelectedCategory as string ?? "all";
    var selectedDate = ViewBag.SelectedDate as string ?? DateTime.Today.ToString("yyyy-MM-dd");
    var categoryCounts = ViewBag.CategoryCounts as Dictionary<string, int> ?? new Dictionary<string, int>();
    var totalCount = (int)(ViewBag.TotalCount ?? 0);
    var unreadCount = (int)(ViewBag.UnreadCount ?? 0);

    var categories = new[] {
        "front-desk", "housekeeping", "maintenance", "security", "general",
        "key-audit", "cash-count", "wake-up-call", "guest-shipment", "ada-compliance"
    };

    var categoryColors = new Dictionary<string, string> {
        { "front-desk", "blue" },
        { "housekeeping", "purple" },
        { "maintenance", "orange" },
        { "security", "red" },
        { "general", "gray" },
        { "key-audit", "yellow" },
        { "cash-count", "green" },
        { "wake-up-call", "indigo" },
        { "guest-shipment", "teal" },
        { "ada-compliance", "pink" }
    };

    var categoryLabels = new Dictionary<string, string> {
        { "front-desk", "Front Desk" },
        { "housekeeping", "Housekeeping" },
        { "maintenance", "Maintenance" },
        { "security", "Security" },
        { "general", "General" },
        { "key-audit", "Key Audit" },
        { "cash-count", "Cash Count" },
        { "wake-up-call", "Wake-Up Call" },
        { "guest-shipment", "Guest Shipment" },
        { "ada-compliance", "ADA Compliance" }
    };

    string GetLabel(string cat)
    {
        return categoryLabels.ContainsKey(cat) ? categoryLabels[cat] : cat;
    }
}

<!-- Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Log Book</h1>
        <p class="text-sm text-gray-500 mt-1">Track and review daily hotel operations</p>
    </div>
    <div class="flex items-center gap-3">
        <span class="bg-amber-100 text-amber-700 px-3 py-1 rounded-full text-sm font-medium">
            @unreadCount unread
        </span>
        <span class="bg-gray-100 text-gray-600 px-3 py-1 rounded-full text-sm font-medium">
            @totalCount total
        </span>
    </div>
</div>

<!-- Create Form -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">New Log Entry</h2>
    <form asp-controller="Logs" asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div class="mb-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Category</label>
                <select name="category" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                    @foreach (var cat in categories)
                    {
                        <option value="@cat">@GetLabel(cat)</option>
                    }
                </select>
            </div>
        </div>
        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Message</label>
            <textarea name="message" required rows="3" placeholder="Describe the log entry..."
                      class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none resize-none"></textarea>
        </div>
        <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-lg text-sm font-medium transition-colors">
            Add Entry
        </button>
    </form>
</div>

<!-- Filters -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-6">
    <div class="flex flex-col sm:flex-row sm:items-center gap-4">
        <!-- Date picker -->
        <form method="get" asp-controller="Logs" asp-action="Index" class="flex items-center gap-2">
            <input type="hidden" name="category" value="@selectedCategory" />
            <label class="text-sm font-medium text-gray-700">Date:</label>
            <input type="date" name="date" value="@selectedDate"
                   onchange="this.form.submit()"
                   class="border border-gray-300 rounded-lg px-3 py-1.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
        </form>
    </div>

    <!-- Category Tabs -->
    <div class="flex flex-wrap gap-2 mt-4">
        <a href="/Logs?category=all&date=@selectedDate"
           class="px-3 py-1.5 rounded-lg text-sm font-medium transition-colors @(selectedCategory == "all" ? "bg-blue-600 text-white" : "bg-gray-100 text-gray-600 hover:bg-gray-200")">
            All (@totalCount)
        </a>
        @foreach (var cat in categories)
        {
            var count = categoryCounts.ContainsKey(cat) ? categoryCounts[cat] : 0;
            var isActive = selectedCategory == cat;
            <a href="/Logs?category=@cat&date=@selectedDate"
               class="px-3 py-1.5 rounded-lg text-sm font-medium transition-colors @(isActive ? "bg-blue-600 text-white" : "bg-gray-100 text-gray-600 hover:bg-gray-200")">
                @GetLabel(cat) (@count)
            </a>
        }
    </div>
</div>

<!-- Log Entries -->
<div class="space-y-3">
    @if (logs.Count == 0)
    {
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-12 text-center">
            <div class="text-gray-400 text-4xl mb-3">&#128221;</div>
            <p class="text-gray-500 text-sm">No log entries found for this date and category.</p>
        </div>
    }
    else
    {
        @foreach (var log in logs)
        {
            var color = categoryColors.ContainsKey(log.Category) ? categoryColors[log.Category] : "gray";
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 @(!log.IsRead ? "border-l-4 border-l-amber-400" : "")">
                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
                    <div class="flex-1">
                        <div class="flex flex-wrap items-center gap-2 mb-2">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-@(color)-100 text-@(color)-700">
                                @GetLabel(log.Category)
                            </span>
                            <span class="text-xs text-gray-400">
                                @log.CreatedAt.ToLocalTime().ToString("h:mm tt")
                            </span>
                            @if (log.IsRead)
                            {
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">
                                    Read
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">
                                    Unread
                                </span>
                            }
                        </div>
                        <p class="text-sm text-gray-800 mb-2">@log.Message</p>
                        <div class="flex flex-wrap items-center gap-3 text-xs text-gray-400">
                            <span>By: <span class="font-medium text-gray-600">@log.CreatedBy</span></span>
                            @if (log.IsRead && log.ReadBy != null)
                            {
                                <span>Read by: <span class="font-medium text-gray-600">@log.ReadBy</span> at @log.ReadAt?.ToLocalTime().ToString("h:mm tt")</span>
                            }
                        </div>
                    </div>

                    <div class="flex items-center gap-2 shrink-0">
                        @if (!log.IsRead)
                        {
                            <form asp-controller="Logs" asp-action="MarkAsRead" method="post" class="flex items-center gap-1">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@log.Id" />
                                <button type="submit" class="bg-green-600 hover:bg-green-700 text-white px-3 py-1 rounded-lg text-xs font-medium transition-colors">
                                    Mark Read
                                </button>
                            </form>
                        }

                        <form asp-controller="Logs" asp-action="Delete" method="post"
                              onsubmit="return swalConfirm(this, 'Are you sure you want to delete this log entry?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@log.Id" />
                            <button type="submit" class="bg-red-50 hover:bg-red-100 text-red-600 px-3 py-1 rounded-lg text-xs font-medium transition-colors">
                                Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
</div>
