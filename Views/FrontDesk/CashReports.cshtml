@model List<CashReport>
@{
    ViewData["Title"] = "Cash Reports";
    var currentDate = (string)ViewBag.CurrentDate ?? "";
}

<div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
            <div class="flex items-center gap-3">
                <a href="/FrontDesk" class="text-gray-400 hover:text-gray-600 transition-colors">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                </a>
                <h1 class="text-2xl font-bold text-gray-900">Cash Reports</h1>
            </div>
            <p class="text-sm text-gray-500 mt-1 ml-8">@Model.Count report(s) found</p>
        </div>
        <a href="/FrontDesk/CreateCashReport" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors whitespace-nowrap">
            New Cash Report
        </a>
    </div>

    <!-- Date Filter -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
        <form method="get" class="flex items-center gap-3">
            <label class="text-sm font-medium text-gray-700">Filter by date:</label>
            <input type="date" name="date" value="@currentDate"
                   class="px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none" />
            <button type="submit" class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-200 transition-colors">Filter</button>
            @if (!string.IsNullOrWhiteSpace(currentDate))
            {
                <a href="/FrontDesk/CashReports" class="px-4 py-2 text-gray-500 hover:text-gray-700 text-sm font-medium transition-colors">Clear</a>
            }
        </form>
    </div>

    <!-- Table -->
    @if (!Model.Any())
    {
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-12 text-center">
            <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <p class="text-gray-400 text-sm">No cash reports found.</p>
            <a href="/FrontDesk/CreateCashReport" class="inline-block mt-3 text-sm text-blue-600 hover:text-blue-700 font-medium">Create one now</a>
        </div>
    }
    else
    {
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-100 bg-gray-50">
                            <th class="text-left px-4 py-3 font-medium text-gray-500">Date</th>
                            <th class="text-left px-4 py-3 font-medium text-gray-500">Shift</th>
                            <th class="text-right px-4 py-3 font-medium text-gray-500">Opening</th>
                            <th class="text-right px-4 py-3 font-medium text-gray-500">Closing</th>
                            <th class="text-right px-4 py-3 font-medium text-gray-500">Cash In</th>
                            <th class="text-right px-4 py-3 font-medium text-gray-500">Cash Out</th>
                            <th class="text-right px-4 py-3 font-medium text-gray-500">CC Total</th>
                            <th class="text-right px-4 py-3 font-medium text-gray-500">Variance</th>
                            <th class="text-left px-4 py-3 font-medium text-gray-500">By</th>
                            <th class="text-center px-4 py-3 font-medium text-gray-500">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        @foreach (var r in Model)
                        {
                            var shiftColor = r.Shift switch
                            {
                                "AM" => "bg-yellow-100 text-yellow-700",
                                "PM" => "bg-blue-100 text-blue-700",
                                "Night" => "bg-indigo-100 text-indigo-700",
                                _ => "bg-gray-100 text-gray-700"
                            };

                            <tr class="hover:bg-gray-50">
                                <td class="px-4 py-3 text-gray-900 font-medium">@r.Date</td>
                                <td class="px-4 py-3">
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium @shiftColor">@r.Shift</span>
                                </td>
                                <td class="px-4 py-3 text-right text-gray-700 font-mono">@r.OpeningBalance.ToString("N2")</td>
                                <td class="px-4 py-3 text-right text-gray-700 font-mono">@r.ClosingBalance.ToString("N2")</td>
                                <td class="px-4 py-3 text-right text-green-700 font-mono">@r.CashIn.ToString("N2")</td>
                                <td class="px-4 py-3 text-right text-red-700 font-mono">@r.CashOut.ToString("N2")</td>
                                <td class="px-4 py-3 text-right text-gray-700 font-mono">@r.CreditCardTotal.ToString("N2")</td>
                                <td class="px-4 py-3 text-right font-mono font-medium @(r.Variance < 0 ? "text-red-600" : r.Variance > 0 ? "text-green-600" : "text-gray-500")">
                                    @(r.Variance >= 0 ? "+" : "")@r.Variance.ToString("N2")
                                </td>
                                <td class="px-4 py-3 text-gray-500 text-xs">@r.CreatedBy</td>
                                <td class="px-4 py-3 text-center">
                                    <a href="/FrontDesk/EditCashReport/@r.Id" class="text-blue-600 hover:text-blue-700 text-xs font-medium">Edit</a>
                                </td>
                            </tr>
                            @if (!string.IsNullOrWhiteSpace(r.Notes))
                            {
                                <tr class="bg-gray-50/50">
                                    <td colspan="10" class="px-4 py-2 text-xs text-gray-500">
                                        <span class="font-medium">Notes:</span> @r.Notes
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
