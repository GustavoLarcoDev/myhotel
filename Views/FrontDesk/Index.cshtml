@{
    ViewData["Title"] = "Front Desk";
    var passLogsToday = (int)ViewBag.PassLogsToday;
    var openComplaints = (int)ViewBag.OpenComplaints;
    var activeLostItems = (int)ViewBag.ActiveLostItems;
    var todayCashReports = (int)ViewBag.TodayCashReports;
}

<div class="space-y-8">
    <!-- Header -->
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Front Desk</h1>
        <p class="text-sm text-gray-500 mt-1">Department dashboard and quick access</p>
    </div>

    <!-- Stat Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Pass Logs Today -->
        <a href="/PassLogs" class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 bg-green-50 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
                </div>
                @if (passLogsToday > 0)
                {
                    <span class="text-xs font-medium bg-green-100 text-green-700 px-2 py-0.5 rounded-full">Today</span>
                }
            </div>
            <p class="text-2xl font-bold text-gray-900">@passLogsToday</p>
            <p class="text-xs text-gray-500 mt-1">Pass Logs Today</p>
        </a>

        <!-- Open Complaints -->
        <a href="/Complaints" class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 bg-red-50 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.832c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
                </div>
                @if (openComplaints > 0)
                {
                    <span class="text-xs font-medium bg-red-100 text-red-700 px-2 py-0.5 rounded-full">Open</span>
                }
            </div>
            <p class="text-2xl font-bold text-gray-900">@openComplaints</p>
            <p class="text-xs text-gray-500 mt-1">Open Complaints</p>
        </a>

        <!-- Active Lost Items -->
        <a href="/LostFound" class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 bg-amber-50 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                </div>
                @if (activeLostItems > 0)
                {
                    <span class="text-xs font-medium bg-amber-100 text-amber-700 px-2 py-0.5 rounded-full">Active</span>
                }
            </div>
            <p class="text-2xl font-bold text-gray-900">@activeLostItems</p>
            <p class="text-xs text-gray-500 mt-1">Active Lost Items</p>
        </a>

        <!-- Cash Reports Today -->
        <a href="/FrontDesk/CashReports" class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                @if (todayCashReports > 0)
                {
                    <span class="text-xs font-medium bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full">Today</span>
                }
            </div>
            <p class="text-2xl font-bold text-gray-900">@todayCashReports</p>
            <p class="text-xs text-gray-500 mt-1">Cash Reports Today</p>
        </a>
    </div>

    <!-- Quick Links -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Quick Links</h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            <a href="/PassLogs" class="flex flex-col items-center gap-2 p-4 bg-gray-50 rounded-xl hover:bg-green-50 hover:text-green-700 transition-colors text-gray-700">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
                <span class="text-xs font-medium">Pass Logs</span>
            </a>
            <a href="/DailyChecks" class="flex flex-col items-center gap-2 p-4 bg-gray-50 rounded-xl hover:bg-blue-50 hover:text-blue-700 transition-colors text-gray-700">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
                <span class="text-xs font-medium">Daily Checks</span>
            </a>
            <a href="/Complaints" class="flex flex-col items-center gap-2 p-4 bg-gray-50 rounded-xl hover:bg-red-50 hover:text-red-700 transition-colors text-gray-700">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.832c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
                <span class="text-xs font-medium">Complaints</span>
            </a>
            <a href="/LostFound" class="flex flex-col items-center gap-2 p-4 bg-gray-50 rounded-xl hover:bg-amber-50 hover:text-amber-700 transition-colors text-gray-700">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                <span class="text-xs font-medium">Lost & Found</span>
            </a>
            <a href="/FrontDesk/CashReports" class="flex flex-col items-center gap-2 p-4 bg-gray-50 rounded-xl hover:bg-emerald-50 hover:text-emerald-700 transition-colors text-gray-700">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span class="text-xs font-medium">Cash Reports</span>
            </a>
            <a href="/Meetings" class="flex flex-col items-center gap-2 p-4 bg-gray-50 rounded-xl hover:bg-purple-50 hover:text-purple-700 transition-colors text-gray-700">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                <span class="text-xs font-medium">Meetings</span>
            </a>
            <a href="/Messaging" class="flex flex-col items-center gap-2 p-4 bg-gray-50 rounded-xl hover:bg-indigo-50 hover:text-indigo-700 transition-colors text-gray-700">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                <span class="text-xs font-medium">Messages</span>
            </a>
            <a href="/Scheduling" class="flex flex-col items-center gap-2 p-4 bg-gray-50 rounded-xl hover:bg-teal-50 hover:text-teal-700 transition-colors text-gray-700">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                <span class="text-xs font-medium">Schedule</span>
            </a>
        </div>
    </div>

    <!-- Department Staff Link -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <div class="flex items-center justify-between">
            <div>
                <h2 class="text-lg font-semibold text-gray-900">Department Staff</h2>
                <p class="text-sm text-gray-500 mt-1">View Front Desk team members</p>
            </div>
            <a href="/FrontDesk/Staff" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors">
                View Staff
            </a>
        </div>
    </div>
</div>
