@{
    ViewData["Title"] = "Notifications";

    var notifications = ViewBag.Notifications as List<Notification> ?? new List<Notification>();
    var unreadCount = (int)(ViewBag.UnreadCount ?? 0);

    string TimeAgo(DateTime dt)
    {
        var span = DateTime.UtcNow - dt;
        if (span.TotalMinutes < 1) return "just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        if (span.TotalDays < 7) return $"{(int)span.TotalDays}d ago";
        return dt.ToLocalTime().ToString("MMM d, yyyy");
    }

    string TypeBgColor(string type) => type switch
    {
        "warning" => "bg-amber-100",
        "success" => "bg-green-100",
        "urgent" => "bg-red-100",
        _ => "bg-blue-100"
    };

    string TypeTextColor(string type) => type switch
    {
        "warning" => "text-amber-600",
        "success" => "text-green-600",
        "urgent" => "text-red-600",
        _ => "text-blue-600"
    };

    string TypeIcon(string type) => type switch
    {
        "warning" => "&#9888;&#65039;",
        "success" => "&#9989;",
        "urgent" => "&#128680;",
        _ => "&#8505;&#65039;"
    };
}

<!-- Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Notifications</h1>
        <p class="text-sm text-gray-500 mt-1">Stay up to date with what's happening</p>
    </div>
    <div class="flex items-center gap-3">
        @if (unreadCount > 0)
        {
            <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-sm font-medium">
                @unreadCount unread
            </span>
            <form asp-controller="Notifications" asp-action="MarkAllRead" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors">
                    Mark All as Read
                </button>
            </form>
        }
        else
        {
            <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm font-medium">
                All caught up
            </span>
        }
    </div>
</div>

<!-- Notifications List -->
<div class="space-y-3">
    @if (notifications.Count == 0)
    {
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-12 text-center">
            <div class="text-gray-400 text-4xl mb-3">&#128276;</div>
            <p class="text-gray-500 text-sm">No notifications yet.</p>
        </div>
    }
    else
    {
        @foreach (var n in notifications)
        {
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 @(!n.IsRead ? "border-l-4 border-l-blue-500" : "")">
                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
                    <div class="flex items-start gap-3 flex-1">
                        <!-- Type Icon -->
                        <div class="@TypeBgColor(n.Type) @TypeTextColor(n.Type) w-10 h-10 rounded-full flex items-center justify-center text-lg shrink-0">
                            @Html.Raw(TypeIcon(n.Type))
                        </div>

                        <div class="flex-1 min-w-0">
                            <div class="flex flex-wrap items-center gap-2 mb-1">
                                <span class="text-sm @(!n.IsRead ? "font-bold text-gray-900" : "font-medium text-gray-700")">
                                    @n.Title
                                </span>
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium @TypeBgColor(n.Type) @TypeTextColor(n.Type)">
                                    @n.Type
                                </span>
                            </div>

                            @if (!string.IsNullOrEmpty(n.Message))
                            {
                                <p class="text-sm text-gray-600 mb-1">@n.Message</p>
                            }

                            <span class="text-xs text-gray-400">@TimeAgo(n.CreatedAt)</span>
                        </div>
                    </div>

                    <div class="flex items-center gap-2 shrink-0">
                        @if (!string.IsNullOrEmpty(n.Link))
                        {
                            <a href="@n.Link" class="bg-blue-50 hover:bg-blue-100 text-blue-600 px-3 py-1.5 rounded-lg text-xs font-medium transition-colors">
                                View
                            </a>
                        }

                        @if (!n.IsRead)
                        {
                            <form asp-controller="Notifications" asp-action="MarkRead" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@n.Id" />
                                <button type="submit" class="bg-green-600 hover:bg-green-700 text-white px-3 py-1.5 rounded-lg text-xs font-medium transition-colors">
                                    Mark Read
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>
