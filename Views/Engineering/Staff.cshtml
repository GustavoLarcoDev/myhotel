@{
    ViewData["Title"] = "Engineering Staff";
    var staffList = (IEnumerable<dynamic>)ViewBag.StaffList;
    var engineeringDepartments = (List<Department>)ViewBag.EngineeringDepartments;
}

<div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Engineering Staff</h1>
            <p class="text-sm text-gray-500 mt-1">Team members in engineering and maintenance departments</p>
        </div>
        <a href="@Url.Action("Index")" class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-200 transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            Back to Engineering
        </a>
    </div>

    <!-- Department Tags -->
    @if (engineeringDepartments.Any())
    {
        <div class="flex items-center gap-2 flex-wrap">
            <span class="text-xs text-gray-500 font-medium">Departments:</span>
            @foreach (var dept in engineeringDepartments)
            {
                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-700">@dept.Name</span>
            }
        </div>
    }

    <!-- Staff Table -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-gray-100">
                        <th class="text-left text-xs font-medium text-gray-500 uppercase tracking-wide px-6 py-3">Name</th>
                        <th class="text-left text-xs font-medium text-gray-500 uppercase tracking-wide px-6 py-3">Email</th>
                        <th class="text-left text-xs font-medium text-gray-500 uppercase tracking-wide px-6 py-3">Phone</th>
                        <th class="text-left text-xs font-medium text-gray-500 uppercase tracking-wide px-6 py-3">Role</th>
                        <th class="text-center text-xs font-medium text-gray-500 uppercase tracking-wide px-6 py-3">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @{
                        var staffCount = 0;
                    }
                    @foreach (var staff in staffList)
                    {
                        staffCount++;
                        ApplicationUser user = staff.User;
                        AppRole role = staff.Role;

                        var roleLabel = role switch
                        {
                            AppRole.Admin => "Admin",
                            AppRole.GeneralManager => "General Manager",
                            AppRole.AssistantGM => "Assistant GM",
                            AppRole.DepartmentManager => "Dept. Manager",
                            AppRole.Employee => "Employee",
                            _ => "Unknown"
                        };

                        var roleColor = role switch
                        {
                            AppRole.Admin => "bg-red-100 text-red-700",
                            AppRole.GeneralManager => "bg-purple-100 text-purple-700",
                            AppRole.AssistantGM => "bg-indigo-100 text-indigo-700",
                            AppRole.DepartmentManager => "bg-blue-100 text-blue-700",
                            AppRole.Employee => "bg-gray-100 text-gray-700",
                            _ => "bg-gray-100 text-gray-700"
                        };

                        <tr class="hover:bg-gray-50">
                            <td class="px-6 py-3">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 bg-gray-200 rounded-full flex items-center justify-center text-xs font-bold text-gray-600">
                                        @(user.FirstName.Length > 0 ? user.FirstName.Substring(0, 1) : "")@(user.LastName.Length > 0 ? user.LastName.Substring(0, 1) : "")
                                    </div>
                                    <span class="text-sm font-medium text-gray-800">@user.FullName</span>
                                </div>
                            </td>
                            <td class="px-6 py-3 text-sm text-gray-600">@(user.Email ?? "-")</td>
                            <td class="px-6 py-3 text-sm text-gray-600">@(user.Phone ?? "-")</td>
                            <td class="px-6 py-3">
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium @roleColor">@roleLabel</span>
                            </td>
                            <td class="px-6 py-3 text-center">
                                @if (user.IsActive)
                                {
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Active</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">Inactive</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (staffCount == 0)
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-12 text-center">
                                <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                <p class="text-sm text-gray-500">No engineering staff found.</p>
                                <p class="text-xs text-gray-400 mt-1">Assign users to the Maintenance or Engineering departments to see them here.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
