@{
    ViewData["Title"] = "Engineering";
    var openWorkOrders = ViewBag.OpenWorkOrders as int? ?? 0;
    var overduePMs = ViewBag.OverduePMs as int? ?? 0;
    var totalAssets = ViewBag.TotalAssets as int? ?? 0;
    var readingsToday = ViewBag.ReadingsToday as int? ?? 0;
    var recentWorkOrders = (List<WorkOrder>)ViewBag.RecentWorkOrders;
    var upcomingPMs = (List<PreventiveMaintenance>)ViewBag.UpcomingPMs;
}

<div class="space-y-8">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Engineering</h1>
            <p class="text-sm text-gray-500 mt-1">Department overview and quick access to engineering modules</p>
        </div>
        <a href="@Url.Action("Staff")" class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            View Staff
        </a>
    </div>

    <!-- Stat Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Open Work Orders -->
        <a href="/WorkOrders" class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 bg-orange-50 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                @if (openWorkOrders > 0)
                {
                    <span class="text-xs font-medium bg-orange-100 text-orange-700 px-2 py-0.5 rounded-full">Open</span>
                }
            </div>
            <p class="text-2xl font-bold text-gray-900">@openWorkOrders</p>
            <p class="text-xs text-gray-500 mt-1">Open Work Orders</p>
        </a>

        <!-- Overdue PMs -->
        <a href="/Maintenance" class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 bg-red-50 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                @if (overduePMs > 0)
                {
                    <span class="text-xs font-medium bg-red-100 text-red-700 px-2 py-0.5 rounded-full">Overdue</span>
                }
            </div>
            <p class="text-2xl font-bold text-gray-900">@overduePMs</p>
            <p class="text-xs text-gray-500 mt-1">Overdue PMs</p>
        </a>

        <!-- Total Assets -->
        <a href="/Assets" class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                </div>
            </div>
            <p class="text-2xl font-bold text-gray-900">@totalAssets</p>
            <p class="text-xs text-gray-500 mt-1">Total Assets</p>
        </a>

        <!-- Readings Today -->
        <a href="/Readings" class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 bg-green-50 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                </div>
            </div>
            <p class="text-2xl font-bold text-gray-900">@readingsToday</p>
            <p class="text-xs text-gray-500 mt-1">Readings Today</p>
        </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Quick Links -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Quick Links</h2>
            <div class="grid grid-cols-2 gap-3">
                <a href="/WorkOrders" class="flex flex-col items-center gap-2 p-4 bg-gray-50 rounded-xl hover:bg-orange-50 hover:text-orange-700 transition-colors text-gray-700">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    <span class="text-xs font-medium">Work Orders</span>
                </a>
                <a href="/Maintenance" class="flex flex-col items-center gap-2 p-4 bg-gray-50 rounded-xl hover:bg-red-50 hover:text-red-700 transition-colors text-gray-700">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <span class="text-xs font-medium">PM Schedule</span>
                </a>
                <a href="/Readings" class="flex flex-col items-center gap-2 p-4 bg-gray-50 rounded-xl hover:bg-green-50 hover:text-green-700 transition-colors text-gray-700">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                    <span class="text-xs font-medium">Readings</span>
                </a>
                <a href="/Assets" class="flex flex-col items-center gap-2 p-4 bg-gray-50 rounded-xl hover:bg-blue-50 hover:text-blue-700 transition-colors text-gray-700">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                    <span class="text-xs font-medium">Assets</span>
                </a>
                <a href="/Meetings" class="flex flex-col items-center gap-2 p-4 bg-gray-50 rounded-xl hover:bg-purple-50 hover:text-purple-700 transition-colors text-gray-700">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    <span class="text-xs font-medium">Meetings</span>
                </a>
                <a href="/Messaging" class="flex flex-col items-center gap-2 p-4 bg-gray-50 rounded-xl hover:bg-indigo-50 hover:text-indigo-700 transition-colors text-gray-700">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    <span class="text-xs font-medium">Messages</span>
                </a>
                <a href="/Scheduling" class="flex flex-col items-center gap-2 p-4 bg-gray-50 rounded-xl hover:bg-teal-50 hover:text-teal-700 transition-colors text-gray-700">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <span class="text-xs font-medium">Schedule</span>
                </a>
                <a href="@Url.Action("Staff")" class="flex flex-col items-center gap-2 p-4 bg-gray-50 rounded-xl hover:bg-cyan-50 hover:text-cyan-700 transition-colors text-gray-700">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    <span class="text-xs font-medium">Staff</span>
                </a>
            </div>
        </div>

        <!-- Recent Open Work Orders -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-semibold text-gray-900">Open Work Orders</h2>
                <a href="/WorkOrders" class="text-xs text-blue-600 hover:text-blue-800 font-medium">View All</a>
            </div>
            <div class="space-y-3">
                @if (recentWorkOrders.Any())
                {
                    foreach (var wo in recentWorkOrders)
                    {
                        var priorityColor = wo.Priority switch
                        {
                            "urgent" => "bg-red-100 text-red-700",
                            "high" => "bg-orange-100 text-orange-700",
                            "normal" => "bg-blue-100 text-blue-700",
                            _ => "bg-gray-100 text-gray-700"
                        };
                        var statusColor = wo.Status switch
                        {
                            "pending" => "bg-amber-100 text-amber-800",
                            "in-progress" => "bg-blue-100 text-blue-800",
                            _ => "bg-gray-100 text-gray-700"
                        };
                        var desc = wo.Description.Length > 50 ? wo.Description.Substring(0, 47) + "..." : wo.Description;

                        <div class="flex items-start gap-3 py-2 border-b border-gray-50 last:border-0">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium @priorityColor whitespace-nowrap mt-0.5">@wo.Priority</span>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm text-gray-900 truncate">@desc</p>
                                <div class="flex items-center gap-2 mt-1">
                                    <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium @statusColor">@wo.Status</span>
                                    @if (!string.IsNullOrWhiteSpace(wo.Room))
                                    {
                                        <span class="text-xs text-gray-400">Room @wo.Room</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-8">
                        <svg class="w-10 h-10 text-gray-300 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        <p class="text-sm text-gray-500">No open work orders</p>
                    </div>
                }
            </div>
        </div>

        <!-- Upcoming PMs -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-semibold text-gray-900">Upcoming PMs</h2>
                <a href="/Maintenance" class="text-xs text-blue-600 hover:text-blue-800 font-medium">View All</a>
            </div>
            <div class="space-y-3">
                @if (upcomingPMs.Any())
                {
                    foreach (var pm in upcomingPMs)
                    {
                        var isOverdue = pm.NextDue < DateTime.UtcNow.Date;
                        var dueColor = isOverdue ? "bg-red-100 text-red-700" : "bg-green-100 text-green-700";
                        var dueLabel = isOverdue ? "Overdue" : "Upcoming";
                        var title = pm.Title.Length > 45 ? pm.Title.Substring(0, 42) + "..." : pm.Title;

                        <div class="flex items-start gap-3 py-2 border-b border-gray-50 last:border-0">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium @dueColor whitespace-nowrap mt-0.5">@dueLabel</span>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm text-gray-900 truncate">@title</p>
                                <div class="flex items-center gap-2 mt-1">
                                    <span class="text-xs text-gray-400">Due @pm.NextDue.ToString("MMM dd, yyyy")</span>
                                    <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">@pm.Frequency</span>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-8">
                        <svg class="w-10 h-10 text-gray-300 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        <p class="text-sm text-gray-500">No upcoming maintenance</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
