@model List<Complaint>
@{
    ViewData["Title"] = "Guest Complaints";
    var currentStatus = (string)ViewBag.CurrentStatus;
    var totalCount = (int)ViewBag.TotalCount;
    var openCount = (int)ViewBag.OpenCount;
    var inProgressCount = (int)ViewBag.InProgressCount;
    var resolvedCount = (int)ViewBag.ResolvedCount;
    var escalatedCount = (int)ViewBag.EscalatedCount;
    var avgResolutionTime = (string)ViewBag.AvgResolutionTime;
}

<!-- Header -->
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Guest Complaints</h1>
        <div class="flex items-center gap-3 mt-2">
            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700">Total: @totalCount</span>
            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">Open: @openCount</span>
            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700">Avg Resolution: @avgResolutionTime</span>
        </div>
    </div>
</div>

<!-- Create Form -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-6">
    <h2 class="text-sm font-semibold text-gray-700 mb-4">File New Complaint</h2>
    <form method="post" asp-action="Create">
        @Html.AntiForgeryToken()
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
            <div>
                <label class="block text-xs font-medium text-gray-500 mb-1">Guest Name *</label>
                <input type="text" name="guestName" required placeholder="Guest name" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none" />
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-500 mb-1">Room</label>
                <input type="text" name="room" placeholder="e.g. 101" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none" />
            </div>
            <div class="lg:col-span-2">
                <label class="block text-xs font-medium text-gray-500 mb-1">Description *</label>
                <textarea name="description" rows="1" required placeholder="Describe the complaint..." class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none resize-none"></textarea>
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-500 mb-1">Created By</label>
                <div class="flex gap-2">
                    <input type="text" name="createdBy" placeholder="Your name" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none" />
                    <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors whitespace-nowrap">File</button>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- Status Filter Tabs -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-6">
    <div class="flex items-center gap-1 flex-wrap">
        @{
            var tabs = new[] {
                ("all", "All", totalCount),
                ("open", "Open", openCount),
                ("in-progress", "In Progress", inProgressCount),
                ("resolved", "Resolved", resolvedCount),
                ("escalated", "Escalated", escalatedCount)
            };
        }
        @foreach (var (val, label, count) in tabs)
        {
            var isActive = currentStatus == val;
            <a href="@Url.Action("Index", new { status = val })"
               class="px-3 py-1.5 rounded-lg text-sm font-medium transition-colors @(isActive ? "bg-blue-100 text-blue-700" : "text-gray-500 hover:text-gray-700 hover:bg-gray-50")">
                @label <span class="ml-1 text-xs">@count</span>
            </a>
        }
    </div>
</div>

<!-- Complaint Cards -->
@if (!Model.Any())
{
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-12 text-center">
        <p class="text-gray-400 text-sm">No complaints found.</p>
    </div>
}
else
{
    <div class="space-y-4">
        @foreach (var c in Model)
        {
            var statusClass = c.Status switch
            {
                "open" => "bg-red-100 text-red-700",
                "in-progress" => "bg-yellow-100 text-yellow-700",
                "resolved" => "bg-green-100 text-green-700",
                _ => "bg-gray-100 text-gray-600"
            };

            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 @(c.IsEscalated ? "ring-2 ring-red-200" : "")">
                <div class="flex flex-col lg:flex-row lg:items-start gap-4">
                    <!-- Main Content -->
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 flex-wrap mb-2">
                            <span class="text-sm font-semibold text-gray-900">@c.GuestName</span>
                            @if (!string.IsNullOrWhiteSpace(c.Room))
                            {
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-bold bg-gray-800 text-white">@c.Room</span>
                            }
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium @statusClass">@c.Status</span>
                            @if (c.IsEscalated)
                            {
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-600 text-white">ESCALATED</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(c.AssignedTo))
                            {
                                <span class="text-xs text-gray-400">Assigned to <span class="font-medium text-gray-600">@c.AssignedTo</span></span>
                            }
                        </div>
                        <p class="text-sm text-gray-800 mb-2">@c.Description</p>

                        @if (!string.IsNullOrWhiteSpace(c.Resolution))
                        {
                            <div class="mt-2 p-3 bg-green-50 rounded-lg">
                                <p class="text-xs font-medium text-green-700 mb-1">Resolution</p>
                                <p class="text-xs text-green-800">@c.Resolution</p>
                            </div>
                        }

                        <!-- Satisfaction Rating -->
                        @if (c.Satisfaction.HasValue)
                        {
                            <div class="mt-2 flex items-center gap-1">
                                <span class="text-xs text-gray-500 mr-1">Satisfaction:</span>
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= c.Satisfaction.Value)
                                    {
                                        <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                                    }
                                    else
                                    {
                                        <svg class="w-4 h-4 text-gray-200" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                                    }
                                }
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(c.CompensationNotes))
                        {
                            <div class="mt-2 p-3 bg-amber-50 rounded-lg">
                                <p class="text-xs font-medium text-amber-700 mb-1">Compensation</p>
                                <p class="text-xs text-amber-800">@c.CompensationNotes</p>
                            </div>
                        }

                        <div class="flex items-center gap-4 text-xs text-gray-400 mt-3">
                            <span>Filed @c.CreatedAt.ToString("MMM dd, yyyy HH:mm") by @c.CreatedBy</span>
                            @if (c.ResolvedAt != null)
                            {
                                <span class="text-green-600">Resolved @c.ResolvedAt.Value.ToString("MMM dd, yyyy HH:mm")</span>
                            }
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="flex flex-col gap-2 lg:w-64 shrink-0">
                        <!-- Update Form -->
                        <form method="post" asp-action="Update" class="space-y-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@c.Id" />
                            <div class="flex gap-1">
                                @{
                                    var cStatuses = new[] { ("open", "Open"), ("in-progress", "In Progress"), ("resolved", "Resolved") };
                                }
                                <select name="status" class="flex-1 px-2 py-1.5 border border-gray-200 rounded-lg text-xs outline-none">
                                    @foreach (var (sv, sl) in cStatuses)
                                    {
                                        if (c.Status == sv)
                                        {
                                            <option value="@sv" selected="selected">@sl</option>
                                        }
                                        else
                                        {
                                            <option value="@sv">@sl</option>
                                        }
                                    }
                                </select>
                            </div>
                            <input type="text" name="assignedTo" value="@c.AssignedTo" placeholder="Assign to..." class="w-full px-2 py-1.5 border border-gray-200 rounded-lg text-xs outline-none" />
                            <textarea name="resolution" rows="1" placeholder="Resolution..." class="w-full px-2 py-1.5 border border-gray-200 rounded-lg text-xs outline-none resize-none">@c.Resolution</textarea>
                            <div class="flex gap-1">
                                <select name="satisfaction" class="flex-1 px-2 py-1.5 border border-gray-200 rounded-lg text-xs outline-none">
                                    <option value="">Satisfaction</option>
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        var starLabel = i == 1 ? "1 Star" : $"{i} Stars";
                                        if (c.Satisfaction == i)
                                        {
                                            <option value="@i" selected="selected">@starLabel</option>
                                        }
                                        else
                                        {
                                            <option value="@i">@starLabel</option>
                                        }
                                    }
                                </select>
                            </div>
                            <input type="text" name="compensationNotes" value="@c.CompensationNotes" placeholder="Compensation notes..." class="w-full px-2 py-1.5 border border-gray-200 rounded-lg text-xs outline-none" />
                            <button type="submit" class="w-full px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-xs font-medium transition-colors">Update</button>
                        </form>

                        <!-- Escalate -->
                        <form method="post" asp-action="Escalate">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@c.Id" />
                            <button type="submit" class="w-full px-3 py-1.5 @(c.IsEscalated ? "bg-amber-100 hover:bg-amber-200 text-amber-700" : "bg-red-50 hover:bg-red-100 text-red-600") rounded-lg text-xs font-medium transition-colors">
                                @(c.IsEscalated ? "Remove Escalation" : "Escalate")
                            </button>
                        </form>

                        <!-- Delete -->
                        <form method="post" asp-action="Delete" onsubmit="return confirm('Delete this complaint?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@c.Id" />
                            <button type="submit" class="w-full px-3 py-1.5 bg-red-50 hover:bg-red-100 text-red-600 rounded-lg text-xs font-medium transition-colors">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
