@model List<MyHotel.Web.Models.Entities.Department>
@{
    ViewData["Title"] = "Departments";
    var hotels = ViewBag.Hotels as List<MyHotel.Web.Models.Entities.Hotel>;
    var selectedHotelId = (int?)ViewBag.SelectedHotelId;
}

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Departments</h1>
            <p class="text-sm text-gray-500 mt-1">@Model.Count department@(Model.Count != 1 ? "s" : "")</p>
        </div>
    </div>

    <!-- Hotel Filter -->
    @if (hotels != null && hotels.Count > 1)
    {
        <div class="flex gap-2 flex-wrap">
            @foreach (var hotel in hotels)
            {
                <a href="/Management/Departments?hotelId=@hotel.Id"
                   class="px-4 py-2 rounded-lg text-sm font-medium transition-colors @(hotel.Id == selectedHotelId ? "bg-blue-600 text-white" : "bg-white text-gray-700 border border-gray-200 hover:bg-gray-50")">
                    @hotel.Name
                </a>
            }
        </div>
    }

    <!-- Add Department -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Add Department</h2>
        <form method="post" action="/Management/CreateDepartment" class="flex gap-3">
            @Html.AntiForgeryToken()
            <input type="hidden" name="hotelId" value="@selectedHotelId" />
            <input type="text" name="name" placeholder="Department name" required
                class="flex-1 border border-gray-200 rounded-lg px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm" />
            <button type="submit" class="bg-blue-600 text-white px-6 py-2.5 rounded-lg hover:bg-blue-700 transition-colors font-medium text-sm">
                Add
            </button>
        </form>
    </div>

    <!-- Department List -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100">
        @if (Model.Count == 0)
        {
            <div class="p-12 text-center">
                <p class="text-gray-500">No departments yet for this hotel.</p>
            </div>
        }
        else
        {
            <div class="divide-y divide-gray-100">
                @foreach (var dept in Model)
                {
                    <div class="px-6 py-4 flex items-center justify-between">
                        <div>
                            <p class="font-medium text-gray-900">@dept.Name</p>
                            <p class="text-xs text-gray-500">@dept.Hotel?.Name</p>
                        </div>
                        <div class="text-sm text-gray-500">
                            @dept.UserDepartments.Count employee@(dept.UserDepartments.Count != 1 ? "s" : "")
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
