@model MyHotel.Web.Models.Entities.Hotel
@{
    ViewData["Title"] = "Edit Hotel";
}

<div class="max-w-2xl mx-auto space-y-6">
    <div>
        <a href="/Management/MyHotels" class="text-sm text-blue-600 hover:underline">← Back to Hotels</a>
        <h1 class="text-2xl font-bold text-gray-900 mt-2">Edit Hotel</h1>
        <p class="text-sm text-gray-500 mt-1">@Model.Name</p>
    </div>

    <form method="post" class="space-y-6">
        @Html.AntiForgeryToken()

        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-600 mb-1">Hotel Name *</label>
                    <input type="text" name="name" value="@Model.Name" required
                        class="w-full border border-gray-200 rounded-lg px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-600 mb-1">Address</label>
                    <input type="text" name="address" value="@Model.Address"
                        class="w-full border border-gray-200 rounded-lg px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm" />
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-600 mb-1">City</label>
                        <input type="text" name="city" value="@Model.City"
                            class="w-full border border-gray-200 rounded-lg px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-600 mb-1">State</label>
                        <input type="text" name="state" value="@Model.State"
                            class="w-full border border-gray-200 rounded-lg px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm" />
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-600 mb-1">Phone</label>
                    <input type="text" name="phone" value="@Model.Phone"
                        class="w-full border border-gray-200 rounded-lg px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm" />
                </div>
                <div>
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" name="isActive" value="true" @(Model.IsActive ? "checked" : "")
                            class="rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
                        <span class="text-sm font-medium text-gray-700">Active</span>
                    </label>
                </div>
            </div>
        </div>

        <div class="flex gap-3">
            <button type="submit" class="bg-blue-600 text-white px-6 py-2.5 rounded-lg hover:bg-blue-700 transition-colors font-medium text-sm">
                Save Changes
            </button>
            <a href="/Management/MyHotels" class="bg-gray-100 text-gray-700 px-6 py-2.5 rounded-lg hover:bg-gray-200 transition-colors font-medium text-sm">
                Cancel
            </a>
        </div>
    </form>
</div>
