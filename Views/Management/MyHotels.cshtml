@model List<MyHotel.Web.Models.Entities.Hotel>
@{
    ViewData["Title"] = "My Hotels";
}

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <a href="/Management" class="text-sm text-blue-600 hover:underline">&larr; Back to Managers</a>
            <h1 class="text-2xl font-bold text-gray-900 mt-2">My Hotels</h1>
            <p class="text-sm text-gray-500 mt-1">@Model.Count hotel@(Model.Count != 1 ? "s" : "")</p>
        </div>
        <a href="/Management/CreateHotel" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors text-sm font-medium">
            + New Hotel
        </a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-12 text-center">
            <p class="text-gray-500">You don't have any hotels yet.</p>
            <a href="/Management/CreateHotel" class="text-blue-600 hover:underline text-sm mt-2 inline-block">Create your first hotel</a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var hotel in Model)
            {
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition-shadow">
                    <div class="flex items-start justify-between">
                        <div>
                            <h3 class="font-semibold text-gray-900 text-lg">@hotel.Name</h3>
                            @if (!string.IsNullOrEmpty(hotel.Address))
                            {
                                <p class="text-sm text-gray-500 mt-1">@hotel.Address</p>
                            }
                            @if (!string.IsNullOrEmpty(hotel.City))
                            {
                                <p class="text-sm text-gray-500">@hotel.City@(hotel.State != null ? $", {hotel.State}" : "")</p>
                            }
                            @if (!string.IsNullOrEmpty(hotel.Phone))
                            {
                                <p class="text-sm text-gray-500">@hotel.Phone</p>
                            }
                        </div>
                        @if (hotel.IsActive)
                        {
                            <span class="inline-flex items-center gap-1 text-xs font-medium text-green-700 bg-green-50 px-2 py-1 rounded-full">
                                <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span> Active
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center gap-1 text-xs font-medium text-red-700 bg-red-50 px-2 py-1 rounded-full">
                                <span class="w-1.5 h-1.5 bg-red-500 rounded-full"></span> Inactive
                            </span>
                        }
                    </div>

                    <div class="flex gap-4 mt-4 pt-4 border-t border-gray-100 text-sm text-gray-500">
                        <span>@hotel.UserRoles.Count staff</span>
                        <span>@hotel.Rooms.Count rooms</span>
                        <span>@hotel.Departments.Count depts</span>
                    </div>

                    <div class="flex gap-2 mt-4">
                        <a href="/Dashboard/SwitchHotel?hotelId=@hotel.Id" class="flex-1 text-center bg-blue-50 text-blue-700 px-3 py-2 rounded-lg hover:bg-blue-100 transition-colors text-sm font-medium">
                            Switch To
                        </a>
                        <a href="/Management/EditHotel/@hotel.Id" class="flex-1 text-center bg-gray-50 text-gray-700 px-3 py-2 rounded-lg hover:bg-gray-100 transition-colors text-sm font-medium">
                            Edit
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>
