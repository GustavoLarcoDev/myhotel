@model List<MyHotel.Web.Models.Entities.ApplicationUser>
@{
    ViewData["Title"] = "All Employees";
    var hotels = ViewBag.Hotels as List<MyHotel.Web.Models.Entities.Hotel>;
    var selectedHotelId = (int?)ViewBag.SelectedHotelId;
}

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <a href="/Management" class="text-sm text-blue-600 hover:underline">&larr; Back to Managers</a>
            <h1 class="text-2xl font-bold text-gray-900 mt-2">All Employees</h1>
            <p class="text-sm text-gray-500 mt-1">@Model.Count employee@(Model.Count != 1 ? "s" : "")</p>
        </div>
        <a href="/Management/CreateUser" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors text-sm font-medium">
            + New Employee
        </a>
    </div>

    <!-- Hotel Filter -->
    @if (hotels != null && hotels.Count > 1)
    {
        <div>
            <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Filter by Hotel</p>
            <div class="flex gap-2 flex-wrap">
                @foreach (var hotel in hotels)
                {
                    <a href="/Management/Users?hotelId=@hotel.Id"
                       class="px-4 py-2 rounded-lg text-sm font-medium transition-colors @(hotel.Id == selectedHotelId ? "bg-blue-600 text-white" : "bg-white text-gray-700 border border-gray-200 hover:bg-gray-50")">
                        @hotel.Name
                    </a>
                }
            </div>
        </div>
    }

    <!-- Department Filter -->
    @{
        var allDepartments = Model
            .SelectMany(u => u.Departments ?? Enumerable.Empty<MyHotel.Web.Models.Entities.UserDepartment>())
            .Where(ud => ud.Department != null)
            .Select(ud => ud.Department!.Name)
            .Distinct()
            .OrderBy(n => n)
            .ToList();
    }
    @if (allDepartments.Any())
    {
        <div x-data="{ selectedDept: '' }">
            <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Filter by Department</p>
            <div class="flex gap-2 flex-wrap">
                <button @@click="selectedDept = ''"
                        :class="selectedDept === '' ? 'bg-purple-600 text-white' : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50'"
                        class="px-4 py-2 rounded-lg text-sm font-medium transition-colors">
                    All
                </button>
                @foreach (var dept in allDepartments)
                {
                    <button @@click="selectedDept = '@dept'"
                            :class="selectedDept === '@dept' ? 'bg-purple-600 text-white' : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50'"
                            class="px-4 py-2 rounded-lg text-sm font-medium transition-colors">
                        @dept
                    </button>
                }
                <button @@click="selectedDept = '__none__'"
                        :class="selectedDept === '__none__' ? 'bg-purple-600 text-white' : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50'"
                        class="px-4 py-2 rounded-lg text-sm font-medium transition-colors">
                    No Department
                </button>
            </div>

            <!-- User Table -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 mt-6">
                @if (Model.Count == 0)
                {
                    <div class="p-12 text-center">
                        <p class="text-gray-500">No employees in this hotel yet.</p>
                        <a href="/Management/CreateUser" class="text-blue-600 hover:underline text-sm mt-2 inline-block">Add an employee</a>
                    </div>
                }
                else
                {
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Role</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Department</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100">
                                @foreach (var user in Model)
                                {
                                    var userRole = user.HotelRoles.FirstOrDefault(r => r.HotelId == selectedHotelId);
                                    var dept = user.Departments?.FirstOrDefault()?.Department;
                                    var deptName = dept?.Name ?? "";
                                    var deptFilterValue = string.IsNullOrEmpty(deptName) ? "__none__" : deptName;
                                    <tr class="hover:bg-gray-50"
                                        x-show="selectedDept === '' || selectedDept === '@deptFilterValue'"
                                        x-transition>
                                        <td class="px-6 py-4">
                                            <div class="flex items-center gap-3">
                                                <div class="w-9 h-9 bg-blue-100 rounded-full flex items-center justify-center text-sm font-bold text-blue-700">
                                                    @(user.FirstName?.Length > 0 ? user.FirstName.Substring(0, 1) : "?")@(user.LastName?.Length > 0 ? user.LastName.Substring(0, 1) : "")
                                                </div>
                                                <div>
                                                    <p class="font-medium text-gray-900">@user.FullName</p>
                                                    @if (user.Phone != null)
                                                    {
                                                        <p class="text-xs text-gray-500">@user.Phone</p>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 text-sm text-gray-600">@user.Email</td>
                                        <td class="px-6 py-4">
                                            @if (userRole != null)
                                            {
                                                var roleColor = userRole.Role switch
                                                {
                                                    MyHotel.Web.Models.Entities.AppRole.GeneralManager => "bg-blue-50 text-blue-700",
                                                    MyHotel.Web.Models.Entities.AppRole.AssistantGM => "bg-indigo-50 text-indigo-700",
                                                    MyHotel.Web.Models.Entities.AppRole.DepartmentManager => "bg-purple-50 text-purple-700",
                                                    _ => "bg-gray-50 text-gray-700"
                                                };
                                                <span class="text-xs px-2 py-0.5 rounded-full @roleColor">@userRole.Role</span>
                                            }
                                        </td>
                                        <td class="px-6 py-4">
                                            @if (dept != null)
                                            {
                                                <span class="text-sm text-gray-600">@dept.Name</span>
                                            }
                                            else
                                            {
                                                <span class="text-sm text-gray-400">&mdash;</span>
                                            }
                                        </td>
                                        <td class="px-6 py-4">
                                            @if (user.IsActive)
                                            {
                                                <span class="inline-flex items-center gap-1 text-xs font-medium text-green-700 bg-green-50 px-2 py-1 rounded-full">
                                                    <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span> Active
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center gap-1 text-xs font-medium text-red-700 bg-red-50 px-2 py-1 rounded-full">
                                                    <span class="w-1.5 h-1.5 bg-red-500 rounded-full"></span> Inactive
                                                </span>
                                            }
                                        </td>
                                        <td class="px-6 py-4 text-right">
                                            <a href="/Management/EditUser/@user.Id" class="text-blue-600 hover:text-blue-800 text-sm font-medium">Edit</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <!-- User Table (no department filter) -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100">
            @if (Model.Count == 0)
            {
                <div class="p-12 text-center">
                    <p class="text-gray-500">No employees in this hotel yet.</p>
                    <a href="/Management/CreateUser" class="text-blue-600 hover:underline text-sm mt-2 inline-block">Add an employee</a>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Role</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Department</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            @foreach (var user in Model)
                            {
                                var userRole = user.HotelRoles.FirstOrDefault(r => r.HotelId == selectedHotelId);
                                var dept = user.Departments?.FirstOrDefault()?.Department;
                                <tr class="hover:bg-gray-50">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="w-9 h-9 bg-blue-100 rounded-full flex items-center justify-center text-sm font-bold text-blue-700">
                                                @(user.FirstName?.Length > 0 ? user.FirstName.Substring(0, 1) : "?")@(user.LastName?.Length > 0 ? user.LastName.Substring(0, 1) : "")
                                            </div>
                                            <div>
                                                <p class="font-medium text-gray-900">@user.FullName</p>
                                                @if (user.Phone != null)
                                                {
                                                    <p class="text-xs text-gray-500">@user.Phone</p>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-gray-600">@user.Email</td>
                                    <td class="px-6 py-4">
                                        @if (userRole != null)
                                        {
                                            var roleColor = userRole.Role switch
                                            {
                                                MyHotel.Web.Models.Entities.AppRole.GeneralManager => "bg-blue-50 text-blue-700",
                                                MyHotel.Web.Models.Entities.AppRole.AssistantGM => "bg-indigo-50 text-indigo-700",
                                                MyHotel.Web.Models.Entities.AppRole.DepartmentManager => "bg-purple-50 text-purple-700",
                                                _ => "bg-gray-50 text-gray-700"
                                            };
                                            <span class="text-xs px-2 py-0.5 rounded-full @roleColor">@userRole.Role</span>
                                        }
                                    </td>
                                    <td class="px-6 py-4">
                                        @if (dept != null)
                                        {
                                            <span class="text-sm text-gray-600">@dept.Name</span>
                                        }
                                        else
                                        {
                                            <span class="text-sm text-gray-400">&mdash;</span>
                                        }
                                    </td>
                                    <td class="px-6 py-4">
                                        @if (user.IsActive)
                                        {
                                            <span class="inline-flex items-center gap-1 text-xs font-medium text-green-700 bg-green-50 px-2 py-1 rounded-full">
                                                <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span> Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center gap-1 text-xs font-medium text-red-700 bg-red-50 px-2 py-1 rounded-full">
                                                <span class="w-1.5 h-1.5 bg-red-500 rounded-full"></span> Inactive
                                            </span>
                                        }
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <a href="/Management/EditUser/@user.Id" class="text-blue-600 hover:text-blue-800 text-sm font-medium">Edit</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }
</div>
