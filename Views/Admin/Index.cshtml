@model List<MyHotel.Web.Models.Entities.ApplicationUser>
@{
    ViewData["Title"] = "Admin Panel";
}

<div class="space-y-8">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Admin Panel</h1>
            <p class="text-sm text-gray-500 mt-1">Manage General Managers</p>
        </div>
        <a href="/Admin/CreateGM" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors text-sm font-medium">
            + New GM
        </a>
    </div>

    <!-- Stat Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center">
                    <svg class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                </div>
                <div>
                    <p class="text-sm font-medium text-gray-500">Total GMs</p>
                    <p class="text-2xl font-bold text-gray-900">@ViewBag.TotalGMs</p>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center">
                    <svg class="w-6 h-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                    <p class="text-sm font-medium text-gray-500">Active GMs</p>
                    <p class="text-2xl font-bold text-gray-900">@ViewBag.ActiveGMs</p>
                </div>
            </div>
        </div>
    </div>

    <!-- GM List -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100">
        <div class="px-6 py-4 border-b border-gray-100">
            <h2 class="text-lg font-semibold text-gray-900">General Managers</h2>
        </div>

        @if (Model.Count == 0)
        {
            <div class="p-12 text-center">
                <p class="text-gray-500">No General Managers yet.</p>
                <a href="/Admin/CreateGM" class="text-blue-600 hover:underline text-sm mt-2 inline-block">Create your first GM</a>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Hotels</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @foreach (var gm in Model)
                        {
                            var gmHotels = gm.HotelRoles.Where(r => r.Role == MyHotel.Web.Models.Entities.AppRole.GeneralManager).Select(r => r.Hotel).ToList();
                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-9 h-9 bg-blue-100 rounded-full flex items-center justify-center text-sm font-bold text-blue-700">
                                            @(gm.FirstName?.Length > 0 ? gm.FirstName.Substring(0, 1) : "?")@(gm.LastName?.Length > 0 ? gm.LastName.Substring(0, 1) : "")
                                        </div>
                                        <div>
                                            <p class="font-medium text-gray-900">@gm.FullName</p>
                                            @if (gm.Phone != null)
                                            {
                                                <p class="text-xs text-gray-500">@gm.Phone</p>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600">@gm.Email</td>
                                <td class="px-6 py-4">
                                    @foreach (var hotel in gmHotels)
                                    {
                                        <span class="inline-block bg-blue-50 text-blue-700 text-xs px-2 py-0.5 rounded-full mr-1 mb-1">@hotel.Name</span>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    @if (gm.IsActive)
                                    {
                                        <span class="inline-flex items-center gap-1 text-xs font-medium text-green-700 bg-green-50 px-2 py-1 rounded-full">
                                            <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span> Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1 text-xs font-medium text-red-700 bg-red-50 px-2 py-1 rounded-full">
                                            <span class="w-1.5 h-1.5 bg-red-500 rounded-full"></span> Inactive
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <a href="/Admin/EditGM/@gm.Id" class="text-blue-600 hover:text-blue-800 text-sm font-medium">Edit</a>
                                        <a href="/Admin/Impersonate?userId=@gm.Id" class="text-amber-600 hover:text-amber-800 text-sm font-medium">Impersonate</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
