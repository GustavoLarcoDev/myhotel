@model AdminCreateUserViewModel
@{
    ViewData["Title"] = "Create User";
    var hotels = ViewBag.Hotels as List<Hotel> ?? new List<Hotel>();
    var departments = ViewBag.Departments as List<Department> ?? new List<Department>();
}

<div class="max-w-2xl mx-auto space-y-6">
    <!-- Header -->
    <div>
        <a href="/Admin/Users" class="text-sm text-gray-500 hover:text-gray-700 flex items-center gap-1 mb-2">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            Back to Users
        </a>
        <h1 class="text-2xl font-bold text-gray-900">Create User</h1>
        <p class="text-sm text-gray-500 mt-1">Add a new user to the system</p>
    </div>

    <form method="post" asp-action="CreateUser" class="space-y-6">
        @Html.AntiForgeryToken()

        <!-- Validation Summary -->
        <div asp-validation-summary="All" class="text-red-600 text-sm"></div>

        <!-- Personal Info -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 space-y-4">
            <h2 class="text-lg font-semibold text-gray-900">Personal Information</h2>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label asp-for="FirstName" class="block text-sm font-medium text-gray-700 mb-1">First Name *</label>
                    <input asp-for="FirstName" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="John" />
                    <span asp-validation-for="FirstName" class="text-red-500 text-xs mt-1"></span>
                </div>
                <div>
                    <label asp-for="LastName" class="block text-sm font-medium text-gray-700 mb-1">Last Name *</label>
                    <input asp-for="LastName" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="Doe" />
                    <span asp-validation-for="LastName" class="text-red-500 text-xs mt-1"></span>
                </div>
            </div>

            <div>
                <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
                <input asp-for="Email" type="email" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="john@hotel.com" />
                <span asp-validation-for="Email" class="text-red-500 text-xs mt-1"></span>
            </div>

            <div>
                <label asp-for="Phone" class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
                <input asp-for="Phone" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="(305) 555-0100" />
            </div>

            <div>
                <label asp-for="Password" class="block text-sm font-medium text-gray-700 mb-1">Password *</label>
                <input asp-for="Password" type="password" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="Minimum 4 characters" />
                <span asp-validation-for="Password" class="text-red-500 text-xs mt-1"></span>
            </div>
        </div>

        <!-- Assignment -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 space-y-4">
            <h2 class="text-lg font-semibold text-gray-900">Hotel Assignment</h2>

            <div>
                <label asp-for="HotelId" class="block text-sm font-medium text-gray-700 mb-1">Hotel *</label>
                <select asp-for="HotelId" id="hotelSelect" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white">
                    <option value="0">Select a hotel...</option>
                    @foreach (var hotel in hotels)
                    {
                        <option value="@hotel.Id">@hotel.Name</option>
                    }
                </select>
            </div>

            <div>
                <label asp-for="Role" class="block text-sm font-medium text-gray-700 mb-1">Role *</label>
                <select asp-for="Role" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white">
                    <option value="@AppRole.Admin">Admin</option>
                    <option value="@AppRole.GeneralManager">General Manager</option>
                    <option value="@AppRole.AssistantGM">Assistant GM</option>
                    <option value="@AppRole.DepartmentManager">Department Manager</option>
                    <option value="@AppRole.Employee" selected>Employee</option>
                </select>
            </div>

            <div>
                <label asp-for="DepartmentId" class="block text-sm font-medium text-gray-700 mb-1">Department</label>
                <select asp-for="DepartmentId" id="departmentSelect" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white">
                    <option value="">No department</option>
                    @foreach (var dept in departments)
                    {
                        <option value="@dept.Id" data-hotel-id="@dept.HotelId">@dept.Name (@dept.HotelId)</option>
                    }
                </select>
                <p class="text-xs text-gray-500 mt-1">Department will be filtered by selected hotel</p>
            </div>
        </div>

        <!-- Submit -->
        <div class="flex items-center justify-end gap-3">
            <a href="/Admin/Users" class="px-4 py-2.5 border border-gray-200 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">Cancel</a>
            <button type="submit" class="bg-blue-600 text-white px-6 py-2.5 rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors">Create User</button>
        </div>
    </form>
</div>

@section Scripts {
<script>
    document.getElementById('hotelSelect').addEventListener('change', function() {
        var hotelId = this.value;
        var deptSelect = document.getElementById('departmentSelect');
        var options = deptSelect.querySelectorAll('option[data-hotel-id]');
        options.forEach(function(opt) {
            opt.style.display = (hotelId === '0' || opt.getAttribute('data-hotel-id') === hotelId) ? '' : 'none';
        });
        deptSelect.value = '';
    });
</script>
}
