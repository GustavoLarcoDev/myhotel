@model List<Department>
@{
    ViewData["Title"] = "Departments";
    var hotels = ViewBag.Hotels as List<Hotel> ?? new List<Hotel>();
    var selectedHotelId = ViewBag.SelectedHotelId as int? ?? hotels.FirstOrDefault()?.Id;
}

<div class="space-y-6">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Departments</h1>
            <p class="text-sm text-gray-500 mt-1">Manage departments across hotels</p>
        </div>
    </div>

    <!-- Hotel Filter -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
        <div class="flex items-center gap-3">
            <span class="text-sm font-medium text-gray-700">Filter by hotel:</span>
            <div class="flex flex-wrap gap-2">
                @foreach (var hotel in hotels)
                {
                    <a href="/Admin/Departments?hotelId=@hotel.Id" class="px-3 py-1.5 rounded-lg text-sm font-medium transition-colors @(selectedHotelId == hotel.Id ? "bg-blue-600 text-white" : "bg-gray-100 text-gray-700 hover:bg-gray-200")">
                        @hotel.Name
                    </a>
                }
            </div>
        </div>
    </div>

    <!-- Add Department Form -->
    @if (selectedHotelId.HasValue)
    {
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Add Department</h2>
            <form method="post" action="/Admin/CreateDepartment" class="flex flex-col sm:flex-row sm:items-end gap-4">
                @Html.AntiForgeryToken()
                <input type="hidden" name="hotelId" value="@selectedHotelId" />
                <div class="flex-1">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Department Name</label>
                    <input name="name" required class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="e.g. Laundry" />
                </div>
                <button type="submit" class="bg-blue-600 text-white px-6 py-2.5 rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors whitespace-nowrap">
                    Add Department
                </button>
            </form>
        </div>
    }

    <!-- Departments Table -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="bg-gray-50 border-b border-gray-100">
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Department</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Hotel</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Members</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Created</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var dept in Model)
                    {
                        var managers = dept.UserDepartments.Where(ud => ud.IsManager).ToList();
                        var members = dept.UserDepartments.Where(ud => !ud.IsManager).ToList();
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4">
                                <div class="font-medium text-gray-900">@dept.Name</div>
                            </td>
                            <td class="px-6 py-4 text-sm text-gray-600">@dept.Hotel.Name</td>
                            <td class="px-6 py-4">
                                <div class="flex flex-col gap-1">
                                    @if (managers.Any())
                                    {
                                        <div class="flex flex-wrap gap-1">
                                            @foreach (var mgr in managers)
                                            {
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                                                    @mgr.User.FullName (Manager)
                                                </span>
                                            }
                                        </div>
                                    }
                                    @if (members.Any())
                                    {
                                        <div class="flex flex-wrap gap-1">
                                            @foreach (var member in members)
                                            {
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700">
                                                    @member.User.FullName
                                                </span>
                                            }
                                        </div>
                                    }
                                    @if (!dept.UserDepartments.Any())
                                    {
                                        <span class="text-xs text-gray-400">No members</span>
                                    }
                                </div>
                            </td>
                            <td class="px-6 py-4 text-sm text-gray-500">@dept.CreatedAt.ToString("MMM d, yyyy")</td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="px-6 py-12 text-center text-sm text-gray-500">No departments found. Select a hotel and add a department.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
