@using Microsoft.AspNetCore.Mvc.Rendering
@model ApplicationUser
@{
    ViewData["Title"] = "Edit User";
    var hotels = ViewBag.Hotels as List<Hotel> ?? new List<Hotel>();
    var departments = ViewBag.Departments as List<Department> ?? new List<Department>();
    var currentRole = Model.HotelRoles.FirstOrDefault();
    var currentDept = Model.Departments.FirstOrDefault();
}

<div class="max-w-2xl mx-auto space-y-6">
    <!-- Header -->
    <div>
        <a href="/Admin/Users" class="text-sm text-gray-500 hover:text-gray-700 flex items-center gap-1 mb-2">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            Back to Users
        </a>
        <h1 class="text-2xl font-bold text-gray-900">Edit User</h1>
        <p class="text-sm text-gray-500 mt-1">Update user details and assignments for @Model.FullName</p>
    </div>

    <form method="post" asp-action="EditUser" asp-route-id="@Model.Id" class="space-y-6">
        @Html.AntiForgeryToken()

        <!-- Personal Info -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 space-y-4">
            <h2 class="text-lg font-semibold text-gray-900">Personal Information</h2>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">First Name</label>
                    <input name="firstName" value="@Model.FirstName" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Last Name</label>
                    <input name="lastName" value="@Model.LastName" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                <input value="@Model.Email" disabled class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm bg-gray-50 text-gray-500" />
                <p class="text-xs text-gray-400 mt-1">Email cannot be changed</p>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
                <input name="phone" value="@Model.Phone" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
            </div>

            <div class="flex items-center gap-3 pt-2">
                <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" name="isActive" value="true" @(Model.IsActive ? "checked" : "") class="sr-only peer" />
                    <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                    <span class="ml-3 text-sm font-medium text-gray-700">Active Account</span>
                </label>
            </div>
        </div>

        <!-- Assignment -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 space-y-4">
            <h2 class="text-lg font-semibold text-gray-900">Hotel Assignment</h2>

            @if (Model.HotelRoles.Count > 1)
            {
                <div class="bg-amber-50 border border-amber-200 rounded-lg p-3 text-sm text-amber-700">
                    This user has roles at multiple hotels. The form below edits the primary role.
                </div>
            }

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Hotel</label>
                @{
                    var hotelSelectItems = hotels.Select(h => new SelectListItem(h.Name, h.Id.ToString(), currentRole?.HotelId == h.Id)).ToList();
                    hotelSelectItems.Insert(0, new SelectListItem("No hotel", "0", currentRole == null));
                }
                <select name="hotelId" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white">
                    @foreach (var item in hotelSelectItems)
                    {
                        @Html.Raw($"<option value=\"{item.Value}\"{(item.Selected ? " selected" : "")}>{item.Text}</option>")
                    }
                </select>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Role</label>
                @{
                    var roleItems = new[]
                    {
                        new { Value = (int)AppRole.Admin, Text = "Admin" },
                        new { Value = (int)AppRole.GeneralManager, Text = "General Manager" },
                        new { Value = (int)AppRole.AssistantGM, Text = "Assistant GM" },
                        new { Value = (int)AppRole.DepartmentManager, Text = "Department Manager" },
                        new { Value = (int)AppRole.Employee, Text = "Employee" }
                    };
                }
                <select name="role" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white">
                    @foreach (var item in roleItems)
                    {
                        var sel = currentRole != null && (int)currentRole.Role == item.Value ? " selected" : "";
                        @Html.Raw($"<option value=\"{item.Value}\"{sel}>{item.Text}</option>")
                    }
                </select>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Department</label>
                @{
                    var deptSelectItems = departments.Select(d => new SelectListItem(d.Name, d.Id.ToString(), currentDept?.DepartmentId == d.Id)).ToList();
                    deptSelectItems.Insert(0, new SelectListItem("No department", "", currentDept == null));
                }
                <select name="departmentId" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white">
                    @foreach (var item in deptSelectItems)
                    {
                        @Html.Raw($"<option value=\"{item.Value}\"{(item.Selected ? " selected" : "")}>{item.Text}</option>")
                    }
                </select>
            </div>
        </div>

        <!-- Current Assignments Summary -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-3">Current Assignments</h2>
            @if (Model.HotelRoles.Any())
            {
                <div class="space-y-2">
                    @foreach (var role in Model.HotelRoles)
                    {
                        var badgeColor = role.Role switch
                        {
                            AppRole.Admin => "bg-red-100 text-red-800",
                            AppRole.GeneralManager => "bg-purple-100 text-purple-800",
                            AppRole.AssistantGM => "bg-indigo-100 text-indigo-800",
                            AppRole.DepartmentManager => "bg-blue-100 text-blue-800",
                            AppRole.Employee => "bg-gray-100 text-gray-800",
                            _ => "bg-gray-100 text-gray-800"
                        };
                        <div class="flex items-center gap-2">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @badgeColor">@role.Role</span>
                            <span class="text-sm text-gray-600">at @role.Hotel.Name</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-sm text-gray-500">No hotel assignments</p>
            }

            @if (Model.Departments.Any())
            {
                <div class="mt-3 pt-3 border-t border-gray-100">
                    <p class="text-sm text-gray-500 mb-1">Departments:</p>
                    @foreach (var dept in Model.Departments)
                    {
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 mr-1">
                            @dept.Department.Name @(dept.IsManager ? "(Manager)" : "")
                        </span>
                    }
                </div>
            }
        </div>

        <!-- Submit -->
        <div class="flex items-center justify-end gap-3">
            <a href="/Admin/Users" class="px-4 py-2.5 border border-gray-200 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">Cancel</a>
            <button type="submit" class="bg-blue-600 text-white px-6 py-2.5 rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors">Save Changes</button>
        </div>
    </form>
</div>
