@{
    ViewData["Title"] = "Asset Inventory";

    var assets = ViewBag.Assets as List<Asset> ?? new List<Asset>();
    var totalCount = (int)ViewBag.TotalCount;
    var warrantyAlertCount = (int)ViewBag.WarrantyAlertCount;
    var selectedCategory = (string)ViewBag.SelectedCategory;
    var selectedCondition = (string)ViewBag.SelectedCondition;
    var search = (string)ViewBag.Search;

    var assetCategories = new[] { "HVAC", "Plumbing", "Electrical", "Elevator", "Kitchen", "Laundry", "IT", "Furniture", "Other" };
    var conditions = new[] { "excellent", "good", "fair", "poor" };

    var today = DateTime.Today;

    string ConditionColor(string c) => c switch
    {
        "excellent" => "green",
        "good" => "blue",
        "fair" => "yellow",
        "poor" => "red",
        _ => "gray"
    };

    string WarrantyStatus(DateTime? expiry)
    {
        if (!expiry.HasValue) return "none";
        if (expiry.Value < today) return "expired";
        if (expiry.Value <= today.AddDays(30)) return "near";
        return "active";
    }

    string WarrantyBadge(string ws) => ws switch
    {
        "active" => "bg-green-100 text-green-700",
        "expired" => "bg-red-100 text-red-700",
        "near" => "bg-amber-100 text-amber-700",
        _ => ""
    };

    string WarrantyLabel(string ws) => ws switch
    {
        "active" => "Active",
        "expired" => "Expired",
        "near" => "Expiring Soon",
        _ => ""
    };
}

<!-- Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Asset Inventory</h1>
        <p class="text-sm text-gray-500 mt-1">Track and manage hotel equipment and assets</p>
    </div>
    <div class="flex items-center gap-3">
        <div class="bg-white border border-gray-200 rounded-lg px-4 py-2 text-sm">
            <span class="text-gray-500">Total:</span>
            <span class="font-bold text-gray-900 ml-1">@totalCount</span>
        </div>
        @if (warrantyAlertCount > 0)
        {
            <div class="bg-amber-50 border border-amber-200 rounded-lg px-4 py-2 text-sm">
                <span class="text-amber-600 font-medium">@warrantyAlertCount warranty expiring soon</span>
            </div>
        }
    </div>
</div>

<!-- Create Form -->
<details class="bg-white rounded-xl border border-gray-200 mb-6 group">
    <summary class="p-5 cursor-pointer select-none hover:bg-gray-50 rounded-xl transition-colors flex items-center justify-between">
        <h2 class="text-sm font-semibold text-gray-700">Add New Asset</h2>
        <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
    </summary>
    <div class="px-5 pb-5 border-t border-gray-100 pt-4">
        <form method="post" action="/Assets/Create">
            @Html.AntiForgeryToken()
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-4">
                <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">Name *</label>
                    <input type="text" name="name" required placeholder="e.g., Carrier AC Unit"
                           class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">Category</label>
                    <select name="category" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                        <option value="">Select...</option>
                        @foreach (var cat in assetCategories)
                        {
                            <option value="@cat">@cat</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">Serial Number</label>
                    <input type="text" name="serialNumber" placeholder="e.g., SN-12345"
                           class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">Location</label>
                    <input type="text" name="location" placeholder="e.g., Room 201, Roof"
                           class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">Condition</label>
                    <select name="condition" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                        @foreach (var c in conditions)
                        {
                            <option value="@c" selected="@(c == "good")">@(char.ToUpper(c[0]) + c.Substring(1))</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">Warranty Expiry</label>
                    <input type="date" name="warrantyExpiry"
                           class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">Purchase Date</label>
                    <input type="date" name="purchaseDate"
                           class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">Purchase Cost</label>
                    <input type="number" name="purchaseCost" step="0.01" placeholder="0.00"
                           class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
                </div>
            </div>
            <button type="submit" class="bg-blue-600 text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors">
                Add Asset
            </button>
        </form>
    </div>
</details>

<!-- Filter Bar -->
<div class="bg-white rounded-xl border border-gray-200 p-4 mb-6">
    <form method="get" action="/Assets" class="flex flex-col sm:flex-row gap-3">
        <select name="category" class="px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
            <option value="all">All Categories</option>
            @foreach (var cat in assetCategories)
            {
                if (selectedCategory == cat)
                {
                    <option value="@cat" selected>@cat</option>
                }
                else
                {
                    <option value="@cat">@cat</option>
                }
            }
        </select>
        <select name="condition" class="px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
            <option value="all">All Conditions</option>
            @foreach (var c in conditions)
            {
                if (selectedCondition == c)
                {
                    <option value="@c" selected>@(char.ToUpper(c[0]) + c.Substring(1))</option>
                }
                else
                {
                    <option value="@c">@(char.ToUpper(c[0]) + c.Substring(1))</option>
                }
            }
        </select>
        <input type="text" name="search" value="@search" placeholder="Search by name, serial#, location..."
               class="flex-1 px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
        <button type="submit" class="bg-blue-600 text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors whitespace-nowrap">
            Filter
        </button>
        @if (selectedCategory != "all" || selectedCondition != "all" || !string.IsNullOrEmpty(search))
        {
            <a href="/Assets" class="px-5 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100 border border-gray-200 transition-colors whitespace-nowrap text-center">
                Clear
            </a>
        }
    </form>
</div>

<!-- Assets Grid -->
@if (assets.Count == 0)
{
    <div class="bg-white rounded-xl border border-gray-200 p-8 text-center">
        <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
        </svg>
        <p class="text-gray-500">No assets found.</p>
    </div>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        @foreach (var asset in assets)
        {
            var condColor = ConditionColor(asset.Condition);
            var ws = WarrantyStatus(asset.WarrantyExpiry);

            <div class="bg-white rounded-xl border border-gray-200 p-5 hover:shadow-md transition-shadow">
                <div class="flex items-start justify-between mb-3">
                    <div class="flex-1 min-w-0">
                        <h3 class="font-semibold text-gray-900 truncate">@asset.Name</h3>
                        @if (!string.IsNullOrEmpty(asset.Category))
                        {
                            <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full bg-indigo-100 text-indigo-700 mt-1">
                                @asset.Category
                            </span>
                        }
                    </div>
                    <span class="inline-flex px-2.5 py-1 text-xs font-medium rounded-full bg-@(condColor)-100 text-@(condColor)-700 capitalize ml-2">
                        @asset.Condition
                    </span>
                </div>

                <div class="space-y-2 text-sm text-gray-600 mb-4">
                    @if (!string.IsNullOrEmpty(asset.SerialNumber))
                    {
                        <div class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14" />
                            </svg>
                            <span class="truncate">@asset.SerialNumber</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(asset.Location))
                    {
                        <div class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                            <span class="truncate">@asset.Location</span>
                        </div>
                    }
                    @if (ws != "none")
                    {
                        <div class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                            </svg>
                            <span>Warranty: @asset.WarrantyExpiry?.ToString("MMM d, yyyy")</span>
                            <span class="inline-flex px-1.5 py-0.5 text-xs font-medium rounded @WarrantyBadge(ws)">@WarrantyLabel(ws)</span>
                        </div>
                    }
                    @if (asset.PurchaseDate.HasValue || asset.PurchaseCost.HasValue)
                    {
                        <div class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            @if (asset.PurchaseCost.HasValue)
                            {
                                <span>$@asset.PurchaseCost.Value.ToString("N2")</span>
                            }
                            @if (asset.PurchaseDate.HasValue)
                            {
                                <span class="text-gray-400">@asset.PurchaseDate.Value.ToString("MMM d, yyyy")</span>
                            }
                        </div>
                    }
                </div>

                <div class="flex items-center gap-2 border-t border-gray-100 pt-3">
                    <!-- Edit Button -->
                    <button type="button" onclick="toggleEdit(@asset.Id)"
                            class="text-blue-600 hover:text-blue-700 text-xs font-medium px-3 py-1.5 rounded-lg hover:bg-blue-50 transition-colors">
                        Edit
                    </button>
                    <!-- Delete -->
                    <form method="post" action="/Assets/Delete" class="ml-auto">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@asset.Id" />
                        <button type="submit" onclick="return swalConfirmBtn(this, 'Delete this asset?')"
                                class="text-gray-400 hover:text-red-500 transition-colors p-1.5">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                        </button>
                    </form>
                </div>

                <!-- Edit Form (hidden by default) -->
                <div id="edit-@asset.Id" class="hidden border-t border-gray-100 pt-4 mt-3">
                    <form method="post" action="/Assets/Edit">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@asset.Id" />
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">
                            <div class="col-span-2">
                                <label class="block text-xs font-medium text-gray-600 mb-1">Name</label>
                                <input type="text" name="name" value="@asset.Name" required
                                       class="w-full px-3 py-1.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none" />
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-600 mb-1">Category</label>
                                <select name="category" class="w-full px-3 py-1.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none">
                                    <option value="">Select...</option>
                                    @foreach (var cat in assetCategories)
                                    {
                                        <option value="@cat" selected="@(asset.Category == cat)">@cat</option>
                                    }
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-600 mb-1">Serial #</label>
                                <input type="text" name="serialNumber" value="@asset.SerialNumber"
                                       class="w-full px-3 py-1.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none" />
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-600 mb-1">Location</label>
                                <input type="text" name="location" value="@asset.Location"
                                       class="w-full px-3 py-1.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none" />
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-600 mb-1">Condition</label>
                                <select name="condition" class="w-full px-3 py-1.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none">
                                    @foreach (var c in conditions)
                                    {
                                        <option value="@c" selected="@(asset.Condition == c)">@(char.ToUpper(c[0]) + c.Substring(1))</option>
                                    }
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-600 mb-1">Warranty Expiry</label>
                                <input type="date" name="warrantyExpiry" value="@(asset.WarrantyExpiry?.ToString("yyyy-MM-dd"))"
                                       class="w-full px-3 py-1.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none" />
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-600 mb-1">Purchase Date</label>
                                <input type="date" name="purchaseDate" value="@(asset.PurchaseDate?.ToString("yyyy-MM-dd"))"
                                       class="w-full px-3 py-1.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none" />
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-600 mb-1">Purchase Cost</label>
                                <input type="number" name="purchaseCost" step="0.01" value="@(asset.PurchaseCost?.ToString("F2"))"
                                       class="w-full px-3 py-1.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none" />
                            </div>
                        </div>
                        <div class="flex gap-2">
                            <button type="submit" class="bg-blue-600 text-white px-4 py-1.5 rounded-lg text-xs font-medium hover:bg-blue-700 transition-colors">
                                Save Changes
                            </button>
                            <button type="button" onclick="toggleEdit(@asset.Id)"
                                    class="px-4 py-1.5 rounded-lg text-xs font-medium text-gray-600 hover:bg-gray-100 border border-gray-200 transition-colors">
                                Cancel
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
<script>
function toggleEdit(id) {
    var el = document.getElementById('edit-' + id);
    if (el) {
        el.classList.toggle('hidden');
    }
}
</script>
}
