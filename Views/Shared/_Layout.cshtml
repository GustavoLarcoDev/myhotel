                                <a href="/Management/CreateUser" class="block px-4 py-2 text-sm text-gray-700 hover:bg-emerald-50 hover:text-emerald-600">Create Employee</a>
                                <a href="/Management/MyHotels" class="block px-4 py-2 text-sm text-gray-700 hover:bg-emerald-50 hover:text-emerald-600">My Hotels</a>
