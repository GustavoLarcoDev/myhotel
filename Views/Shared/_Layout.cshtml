@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using MyHotel.Web.Models.Entities
@using MyHotel.Web.Services
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject HotelContextService HotelContext
@inject ImpersonationService Impersonation
@inject MyHotel.Web.Data.ApplicationDbContext Db
@inject MyHotel.Web.Services.NotificationService NotificationSvc
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MyHotel</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        [x-cloak] { display: none !important; }
        @@media (min-width: 1024px) {
            .dropdown:hover .dropdown-menu { display: block; }
        }
        .dropdown button:focus { outline: none; }
        .dropdown button { outline: none; border: none; }

        /* Theme: Light (default) */
        [data-theme="light"] { --bg-base: 249 250 251; --bg-card: 255 255 255; --bg-nav: 255 255 255; --text-primary: 17 24 39; --text-secondary: 107 114 128; --border-color: 229 231 235; --accent: 37 99 235; }
        /* Theme: Dark */
        [data-theme="dark"] { --bg-base: 17 24 39; --bg-card: 31 41 55; --bg-nav: 17 24 39; --text-primary: 243 244 246; --text-secondary: 156 163 175; --border-color: 55 65 81; --accent: 96 165 250; }
        [data-theme="dark"] body { background-color: rgb(17 24 39) !important; color: rgb(243 244 246) !important; }
        [data-theme="dark"] .bg-white, [data-theme="dark"] .bg-gray-50 { background-color: rgb(31 41 55) !important; }
        [data-theme="dark"] .bg-gray-100 { background-color: rgb(55 65 81) !important; }
        [data-theme="dark"] .text-gray-900, [data-theme="dark"] .text-gray-800 { color: rgb(243 244 246) !important; }
        [data-theme="dark"] .text-gray-700, [data-theme="dark"] .text-gray-600, [data-theme="dark"] .text-gray-500 { color: rgb(156 163 175) !important; }
        [data-theme="dark"] .text-gray-400, [data-theme="dark"] .text-gray-300 { color: rgb(107 114 128) !important; }
        [data-theme="dark"] .border-gray-200, [data-theme="dark"] .border-gray-100 { border-color: rgb(55 65 81) !important; }
        [data-theme="dark"] .border-gray-300 { border-color: rgb(75 85 99) !important; }
        [data-theme="dark"] .shadow-sm { box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.3) !important; }
        [data-theme="dark"] input, [data-theme="dark"] select, [data-theme="dark"] textarea { background-color: rgb(55 65 81) !important; color: rgb(243 244 246) !important; border-color: rgb(75 85 99) !important; }
        [data-theme="dark"] .hover\:bg-gray-50:hover { background-color: rgb(55 65 81) !important; }
        [data-theme="dark"] .hover\:bg-gray-100:hover { background-color: rgb(75 85 99) !important; }
        [data-theme="dark"] table th { background-color: rgb(31 41 55) !important; color: rgb(156 163 175) !important; }
        [data-theme="dark"] table td { border-color: rgb(55 65 81) !important; }
        [data-theme="dark"] .swal2-popup { background: rgb(31 41 55) !important; color: rgb(243 244 246) !important; }
        [data-theme="dark"] .swal2-title, [data-theme="dark"] .swal2-html-container { color: rgb(243 244 246) !important; }
        [data-theme="dark"] .dropdown-menu { background-color: rgb(31 41 55) !important; border-color: rgb(55 65 81) !important; }
        [data-theme="dark"] .dropdown-menu a, [data-theme="dark"] .dropdown-menu button { color: rgb(209 213 219) !important; }
        [data-theme="dark"] .dropdown-menu a:hover, [data-theme="dark"] .dropdown-menu button:hover { background-color: rgb(55 65 81) !important; }
        [data-theme="dark"] nav { background-color: rgb(17 24 39) !important; border-color: rgb(55 65 81) !important; }
        [data-theme="dark"] .bg-green-50 { background-color: rgb(20 51 36) !important; }
        [data-theme="dark"] .bg-red-50 { background-color: rgb(51 20 20) !important; }
        [data-theme="dark"] .bg-amber-50 { background-color: rgb(51 42 20) !important; }
        [data-theme="dark"] .rounded-xl.shadow-sm { background-color: rgb(31 41 55) !important; }

        /* Theme: Sunset */
        [data-theme="sunset"] body { background-color: rgb(254 243 235) !important; }
        [data-theme="sunset"] .bg-white { background-color: rgb(255 251 247) !important; }
        [data-theme="sunset"] .bg-gray-50 { background-color: rgb(254 243 235) !important; }
        [data-theme="sunset"] .bg-blue-600 { background-color: rgb(234 88 12) !important; }
        [data-theme="sunset"] .bg-blue-700, [data-theme="sunset"] .hover\:bg-blue-700:hover { background-color: rgb(194 65 12) !important; }
        [data-theme="sunset"] .text-blue-600 { color: rgb(234 88 12) !important; }
        [data-theme="sunset"] .text-blue-700 { color: rgb(194 65 12) !important; }
        [data-theme="sunset"] .border-blue-600 { border-color: rgb(234 88 12) !important; }
        [data-theme="sunset"] .bg-blue-100 { background-color: rgb(255 237 213) !important; }
        [data-theme="sunset"] .bg-blue-50 { background-color: rgb(255 247 237) !important; }
        [data-theme="sunset"] .ring-blue-500 { --tw-ring-color: rgb(251 146 60) !important; }
        [data-theme="sunset"] .focus\:ring-blue-500:focus { --tw-ring-color: rgb(251 146 60) !important; }
        [data-theme="sunset"] nav, [data-theme="sunset"] .bg-white.shadow-sm.border-b { background-color: rgb(255 247 237) !important; }

        /* Theme: Ocean */
        [data-theme="ocean"] body { background-color: rgb(236 246 254) !important; }
        [data-theme="ocean"] .bg-white { background-color: rgb(240 249 255) !important; }
        [data-theme="ocean"] .bg-gray-50 { background-color: rgb(236 246 254) !important; }
        [data-theme="ocean"] .bg-blue-600 { background-color: rgb(14 116 144) !important; }
        [data-theme="ocean"] .bg-blue-700, [data-theme="ocean"] .hover\:bg-blue-700:hover { background-color: rgb(21 94 117) !important; }
        [data-theme="ocean"] .text-blue-600 { color: rgb(14 116 144) !important; }
        [data-theme="ocean"] .text-blue-700 { color: rgb(21 94 117) !important; }
        [data-theme="ocean"] .border-blue-600 { border-color: rgb(14 116 144) !important; }
        [data-theme="ocean"] .bg-blue-100 { background-color: rgb(207 250 254) !important; }
        [data-theme="ocean"] .bg-blue-50 { background-color: rgb(236 254 255) !important; }
        [data-theme="ocean"] .ring-blue-500 { --tw-ring-color: rgb(6 182 212) !important; }
        [data-theme="ocean"] .focus\:ring-blue-500:focus { --tw-ring-color: rgb(6 182 212) !important; }
    </style>
    <script>
        (function() {
            var theme = localStorage.getItem('myhotel-theme') || 'light';
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
    function swalConfirm(form, message) {
        Swal.fire({
            title: 'Are you sure?',
            text: message || 'This action cannot be undone.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Yes, proceed',
            cancelButtonText: 'Cancel',
            reverseButtons: true
        }).then(function(result) {
            if (result.isConfirmed) {
                form.removeAttribute('onsubmit');
                form.submit();
            }
        });
        return false;
    }
    function setTheme(theme) {
        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('myhotel-theme', theme);
    }
    function swalConfirmBtn(btn, message) {
        Swal.fire({
            title: 'Are you sure?',
            text: message || 'This action cannot be undone.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Yes, proceed',
            cancelButtonText: 'Cancel',
            reverseButtons: true
        }).then(function(result) {
            if (result.isConfirmed) {
                btn.removeAttribute('onclick');
                btn.closest('form').submit();
            }
        });
        return false;
    }
    </script>
</head>
<body class="bg-gray-50 min-h-screen">
    @if (SignInManager.IsSignedIn(User))
    {
        var currentUser = await UserManager.GetUserAsync(User);
        var currentHotel = await HotelContext.GetCurrentHotel();
        var userHotels = currentUser != null ? await HotelContext.GetUserHotels(currentUser.Id) : new List<Hotel>();
        var isAdmin = currentUser != null && await Db.UserHotelRoles.AnyAsync(r => r.UserId == currentUser.Id && r.Role == AppRole.Admin);
        var isGM = currentUser != null && await Db.UserHotelRoles.AnyAsync(r => r.UserId == currentUser.Id && r.Role == AppRole.GeneralManager);
        var unreadCount = (currentUser != null && currentHotel != null) ? await NotificationSvc.GetUnreadCountAsync(currentUser.Id, currentHotel.Id) : 0;

        <!-- Impersonation Banner -->
        @if (Impersonation.IsImpersonating)
        {
            <div class="bg-amber-500 text-white text-center py-2 text-sm font-medium">
                Impersonating user. <a href="/Admin/StopImpersonation" class="underline font-bold ml-2">Stop Impersonation</a>
            </div>
        }

        <!-- Top Navbar -->
        <nav class="bg-white border-b border-gray-200 shadow-sm sticky top-0 z-50">
            <div class="max-w-7xl mx-auto px-4">
                <div class="flex items-center justify-between h-16">
                    <!-- Logo -->
                    <a href="/" class="flex items-center gap-2 text-xl font-bold text-blue-600">
                        <span class="bg-blue-600 text-white w-8 h-8 rounded-lg flex items-center justify-center text-sm">H</span>
                        MyHotel
                    </a>

                    <!-- Nav Links -->
                    <div class="hidden lg:flex items-center gap-1">
                        @if (!isAdmin || Impersonation.IsImpersonating)
                        {
                        <!-- Sales -->
