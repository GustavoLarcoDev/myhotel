                    </div>

                    <!-- Right Side -->
                    <div class="flex items-center gap-3">
                        @if (currentHotel != null && (!isAdmin || Impersonation.IsImpersonating))
                        {
                            <!-- Hotel Switcher -->
                            @if (userHotels.Count > 1)
                            {
                                <div class="dropdown relative">
                                    <button class="flex items-center gap-2 bg-blue-50 text-blue-700 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-blue-100 transition-colors focus:outline-none focus:ring-0">
                                        <span class="w-2 h-2 bg-blue-500 rounded-full animate-pulse"></span>
                                        @currentHotel.Name
                                        <svg class="w-3.5 h-3.5 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                                    </button>
                                    <div class="dropdown-menu hidden absolute right-0 top-full mt-1 w-56 bg-white rounded-lg shadow-lg border border-gray-100 py-1 z-50">
                                        @foreach (var h in userHotels)
                                        {
                                            <a href="/Dashboard/SwitchHotel?hotelId=@h.Id" class="block px-4 py-2 text-sm @(h.Id == currentHotel.Id ? "bg-blue-50 text-blue-700 font-semibold" : "text-gray-700 hover:bg-gray-50")">
                                                @h.Name
                                            </a>
                                        }
                                    </div>
                                </div>
                            }
                            else
                            {
                                <span class="bg-blue-50 text-blue-700 px-3 py-1.5 rounded-lg text-sm font-medium">@currentHotel.Name</span>
                            }
                        }

                        <!-- Notification Bell -->
                        <a href="/Notifications" class="notification-bell relative p-2 text-gray-600 hover:text-gray-900">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                            @if (unreadCount > 0)
                            {
                                <span class="notification-badge absolute -top-0.5 -right-0.5 bg-red-500 text-white text-xs w-4 h-4 flex items-center justify-center rounded-full">@unreadCount</span>
                            }
                        </a>

                        <!-- Theme Switcher -->
                        <div class="dropdown relative">
                            <button class="p-2 text-gray-600 hover:text-gray-900 rounded-lg hover:bg-gray-100 transition-colors" title="Change theme">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>
                            </button>
                            <div class="dropdown-menu hidden absolute right-0 top-full mt-1 w-44 bg-white rounded-lg shadow-lg border border-gray-100 py-1 z-50">
