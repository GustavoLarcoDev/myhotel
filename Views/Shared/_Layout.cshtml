                        }

                        <!-- Admin (only for admin, not while impersonating) -->
                        @if (isAdmin && !Impersonation.IsImpersonating)
                        {
                        <div class="dropdown relative">
                            <button class="px-3 py-2 text-sm font-medium text-red-600 hover:text-red-700 hover:bg-red-50 rounded-lg transition-colors">Admin</button>
                            <div class="dropdown-menu hidden absolute left-0 top-full mt-0 w-48 bg-white rounded-lg shadow-lg border border-gray-100 py-1 z-50">
