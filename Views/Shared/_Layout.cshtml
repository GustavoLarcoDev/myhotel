                            <div class="dropdown-menu hidden absolute left-0 top-full mt-0 w-48 bg-white rounded-lg shadow-lg border border-gray-100 py-1 z-50">
                                <a href="/Sales" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Overview</a>
                                <a href="/Sales/GroupSales" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Group Sales</a>
                                <a href="/Meetings?dept=sales" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Meetings</a>
                                <a href="/Messaging?dept=sales" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Messages</a>
                                <a href="/Scheduling?dept=sales" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Schedule</a>
                                <a href="/Inventory?dept=sales" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Inventory</a>
                                <a href="/Sales/Staff" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Staff</a>
                            </div>
                        </div>

                        <!-- Engineering -->
                        <div class="dropdown relative">
                            <button class="px-3 py-2 text-sm font-medium text-gray-700 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">Engineering</button>
                            <div class="dropdown-menu hidden absolute left-0 top-full mt-0 w-48 bg-white rounded-lg shadow-lg border border-gray-100 py-1 z-50">
                                <a href="/Engineering" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Overview</a>
                                <a href="/WorkOrders" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Work Orders</a>
                                <a href="/Maintenance" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">PM Schedule</a>
                                <a href="/Readings" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Readings</a>
                                <a href="/Assets" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Assets</a>
                                <a href="/Meetings?dept=engineering" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Meetings</a>
                                <a href="/Messaging?dept=engineering" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Messages</a>
                                <a href="/Scheduling?dept=engineering" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Schedule</a>
                                <a href="/Inventory?dept=engineering" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Inventory</a>
                                <a href="/Engineering/Staff" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Staff</a>
                            </div>
                        </div>

                        <!-- Front Desk -->
                        <div class="dropdown relative">
                            <button class="px-3 py-2 text-sm font-medium text-gray-700 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">Front Desk</button>
                            <div class="dropdown-menu hidden absolute left-0 top-full mt-0 w-48 bg-white rounded-lg shadow-lg border border-gray-100 py-1 z-50">
                                <a href="/FrontDesk" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Overview</a>
                                <a href="/PassLogs" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Pass Logs</a>
                                <a href="/DailyChecks" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Daily Checks</a>
                                <a href="/Complaints" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Complaints</a>
                                <a href="/LostFound" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Lost &amp; Found</a>
                                <a href="/FrontDesk/CashReports" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Cash Reports</a>
                                <a href="/Meetings?dept=frontdesk" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Meetings</a>
                                <a href="/Messaging?dept=frontdesk" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Messages</a>
                                <a href="/Scheduling?dept=frontdesk" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Schedule</a>
                                <a href="/FrontDesk/Staff" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Staff</a>
                            </div>
                        </div>

                        <!-- Housekeeping -->
                        <div class="dropdown relative">
                            <button class="px-3 py-2 text-sm font-medium text-gray-700 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">Housekeeping</button>
                            <div class="dropdown-menu hidden absolute left-0 top-full mt-0 w-48 bg-white rounded-lg shadow-lg border border-gray-100 py-1 z-50">
                                <a href="/Housekeeping" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Overview</a>
                                <a href="/Rooms" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Rooms</a>
                                <a href="/Housekeeping/CleaningRequests" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Cleaning Requests</a>
                                <a href="/DailyChecks?dept=housekeeping" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Daily Checks</a>
                                <a href="/Meetings?dept=housekeeping" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Meetings</a>
                                <a href="/Messaging?dept=housekeeping" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Messages</a>
                                <a href="/Scheduling?dept=housekeeping" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Schedule</a>
                                <a href="/Inventory?dept=housekeeping" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Inventory</a>
                                <a href="/Housekeeping/Staff" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Staff</a>
                            </div>
                        </div>

                        <!-- Administrative -->
                        <div class="dropdown relative">
                            <button class="px-3 py-2 text-sm font-medium text-gray-700 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">Administrative</button>
                            <div class="dropdown-menu hidden absolute left-0 top-full mt-0 w-48 bg-white rounded-lg shadow-lg border border-gray-100 py-1 z-50">
                                <a href="/Administrative" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Overview</a>
                                <a href="/Budget" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Budget</a>
                                <a href="/Reports" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Reports</a>
                                <a href="/Evaluations" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Evaluations</a>
                                <a href="/Directory" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Directory</a>
                                <a href="/Meetings?dept=administrative" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Meetings</a>
                                <a href="/Administrative/Staff" class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600">Staff</a>
                            </div>
                        </div>
                        }

                        <!-- Managers (for GM, not while impersonating) -->
                        @if (isGM && !Impersonation.IsImpersonating)
                        {
                        <div class="dropdown relative">
                            <button class="px-3 py-2 text-sm font-medium text-emerald-600 hover:text-emerald-700 hover:bg-emerald-50 rounded-lg transition-colors">Managers</button>
                            <div class="dropdown-menu hidden absolute left-0 top-full mt-0 w-48 bg-white rounded-lg shadow-lg border border-gray-100 py-1 z-50">
