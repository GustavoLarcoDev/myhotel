@model List<WorkOrder>
@{
    ViewData["Title"] = "Work Orders";
    var currentStatus = (string)ViewBag.CurrentStatus;
    var currentSearch = (string)ViewBag.CurrentSearch ?? "";
    var currentSort = (string)ViewBag.CurrentSort;
    var totalCount = (int)ViewBag.TotalCount;
    var pendingCount = (int)ViewBag.PendingCount;
    var inProgressCount = (int)ViewBag.InProgressCount;
    var completedCount = (int)ViewBag.CompletedCount;
}

<!-- Header -->
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Work Orders</h1>
        <div class="flex items-center gap-3 mt-2 flex-wrap">
            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700">Total: @totalCount</span>
            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-700">Pending: @pendingCount</span>
            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700">In Progress: @inProgressCount</span>
            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Completed: @completedCount</span>
        </div>
    </div>
</div>

<!-- Create Form -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-6">
    <h2 class="text-sm font-semibold text-gray-700 mb-4">New Work Order</h2>
    <form method="post" asp-action="Create">
        @Html.AntiForgeryToken()
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <div>
                <label class="block text-xs font-medium text-gray-500 mb-1">Room</label>
                <input type="text" name="room" placeholder="e.g. 101" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none" />
            </div>
            <div class="sm:col-span-2">
                <label class="block text-xs font-medium text-gray-500 mb-1">Description *</label>
                <textarea name="description" rows="1" required placeholder="What needs to be done..." class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none resize-none"></textarea>
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-500 mb-1">Priority</label>
                <select name="priority" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none">
                    <option value="low">Low</option>
                    <option value="normal" selected>Normal</option>
                    <option value="high">High</option>
                    <option value="urgent">Urgent</option>
                </select>
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-500 mb-1">Assigned To</label>
                <input type="text" name="assignedTo" placeholder="Name" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none" />
            </div>
            <div class="flex items-end">
                <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors whitespace-nowrap">Add</button>
            </div>
        </div>
    </form>
</div>

<!-- Filter Bar -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-6">
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <!-- Status Tabs -->
        <div class="flex items-center gap-1 flex-wrap">
            @{
                var statuses = new[] {
                    ("all", "All", totalCount),
                    ("pending", "Pending", pendingCount),
                    ("in-progress", "In Progress", inProgressCount),
                    ("completed", "Completed", completedCount)
                };
            }
            @foreach (var (val, label, count) in statuses)
            {
                var isActive = currentStatus == val;
                <a href="@Url.Action("Index", new { status = val, search = currentSearch, sort = currentSort })"
                   class="px-3 py-1.5 rounded-lg text-sm font-medium transition-colors @(isActive ? "bg-blue-100 text-blue-700" : "text-gray-500 hover:text-gray-700 hover:bg-gray-50")">
                    @label <span class="ml-1 text-xs">@count</span>
                </a>
            }
        </div>

        <div class="flex items-center gap-3 sm:ml-auto w-full sm:w-auto">
            <!-- Search -->
            <form method="get" asp-action="Index" class="flex-1 sm:flex-none">
                <input type="hidden" name="status" value="@currentStatus" />
                <input type="hidden" name="sort" value="@currentSort" />
                <input type="text" name="search" value="@currentSearch" placeholder="Search..."
                       class="w-full sm:w-48 px-3 py-1.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none" />
            </form>
            <!-- Sort -->
            <form method="get" asp-action="Index" id="sortForm">
                <input type="hidden" name="status" value="@currentStatus" />
                <input type="hidden" name="search" value="@currentSearch" />
                @{
                    var sortOptions = new[] { ("newest", "Newest"), ("oldest", "Oldest"), ("priority", "Priority") };
                }
                <select name="sort" onchange="document.getElementById('sortForm').submit()"
                        class="px-3 py-1.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none">
                    @foreach (var (sVal, sLabel) in sortOptions)
                    {
                        if (currentSort == sVal)
                        {
                            <option value="@sVal" selected="selected">@sLabel</option>
                        }
                        else
                        {
                            <option value="@sVal">@sLabel</option>
                        }
                    }
                </select>
            </form>
        </div>
    </div>
</div>

<!-- Work Order Cards -->
@if (!Model.Any())
{
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-12 text-center">
        <p class="text-gray-400 text-sm">No work orders found.</p>
    </div>
}
else
{
    <div class="space-y-4">
        @foreach (var wo in Model)
        {
            var priorityClass = wo.Priority switch
            {
                "low" => "bg-gray-100 text-gray-600",
                "high" => "bg-orange-100 text-orange-700",
                "urgent" => "bg-red-100 text-red-700",
                _ => "bg-blue-100 text-blue-700"
            };
            var statusClass = wo.Status switch
            {
                "pending" => "bg-yellow-100 text-yellow-700",
                "in-progress" => "bg-blue-100 text-blue-700",
                "completed" => "bg-green-100 text-green-700",
                _ => "bg-gray-100 text-gray-600"
            };

            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
                <div class="flex flex-col lg:flex-row lg:items-start gap-4">
                    <!-- Main Content -->
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 flex-wrap mb-2">
                            @if (!string.IsNullOrWhiteSpace(wo.Room))
                            {
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-bold bg-gray-800 text-white">@wo.Room</span>
                            }
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium @priorityClass">@wo.Priority</span>
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium @statusClass">@wo.Status</span>
                            @if (!string.IsNullOrWhiteSpace(wo.AssignedTo))
                            {
                                <span class="text-xs text-gray-400">Assigned to <span class="font-medium text-gray-600">@wo.AssignedTo</span></span>
                            }
                        </div>
                        <p class="text-sm text-gray-800 mb-2">@wo.Description</p>
                        <div class="flex items-center gap-4 text-xs text-gray-400">
                            <span>Created @wo.CreatedAt.ToString("MMM dd, yyyy HH:mm") by @wo.CreatedBy</span>
                            @if (wo.CompletedAt != null)
                            {
                                <span class="text-green-600">Completed @wo.CompletedAt.Value.ToString("MMM dd, yyyy HH:mm")</span>
                            }
                        </div>

                        <!-- Notes -->
                        @if (!string.IsNullOrWhiteSpace(wo.Notes))
                        {
                            <div class="mt-3 p-3 bg-gray-50 rounded-lg">
                                <p class="text-xs font-medium text-gray-500 mb-1">Notes</p>
                                @foreach (var line in wo.Notes.Split('\n'))
                                {
                                    <p class="text-xs text-gray-600">@line</p>
                                }
                            </div>
                        }
                    </div>

                    <!-- Actions -->
                    <div class="flex flex-col gap-2 lg:w-56 shrink-0">
                        <!-- Update Status -->
                        <form method="post" asp-action="UpdateStatus" class="flex gap-1">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@wo.Id" />
                            @{
                                var woStatuses = new[] { ("pending", "Pending"), ("in-progress", "In Progress"), ("completed", "Completed") };
                            }
                            <select name="status" class="flex-1 px-2 py-1.5 border border-gray-200 rounded-lg text-xs outline-none">
                                @foreach (var (sv, sl) in woStatuses)
                                {
                                    if (wo.Status == sv)
                                    {
                                        <option value="@sv" selected="selected">@sl</option>
                                    }
                                    else
                                    {
                                        <option value="@sv">@sl</option>
                                    }
                                }
                            </select>
                            <button type="submit" class="px-3 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg text-xs font-medium transition-colors">Update</button>
                        </form>

                        <!-- Add Note -->
                        <form method="post" asp-action="AddNote" class="flex gap-1">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@wo.Id" />
                            <input type="text" name="notes" placeholder="Add note..." class="flex-1 px-2 py-1.5 border border-gray-200 rounded-lg text-xs outline-none" />
                            <button type="submit" class="px-3 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg text-xs font-medium transition-colors">Note</button>
                        </form>

                        <!-- Delete -->
                        <form method="post" asp-action="Delete" onsubmit="return swalConfirm(this, 'Delete this work order?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@wo.Id" />
                            <button type="submit" class="w-full px-3 py-1.5 bg-red-50 hover:bg-red-100 text-red-600 rounded-lg text-xs font-medium transition-colors">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
