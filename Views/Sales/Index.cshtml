@{
    ViewData["Title"] = "Sales Department";
    var totalSales = (int)ViewBag.TotalSales;
    var totalRevenue = (decimal)ViewBag.TotalRevenue;
    var pendingCount = (int)ViewBag.PendingCount;
    var confirmedCount = (int)ViewBag.ConfirmedCount;
    var recentSales = (List<GroupSale>)ViewBag.RecentSales;
}

<div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Sales Department</h1>
            <p class="text-sm text-gray-500 mt-1">Overview of group sales and revenue</p>
        </div>
        <div class="flex items-center gap-2">
            <a href="@Url.Action("CreateGroupSale")" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors">
                + New Group Sale
            </a>
        </div>
    </div>

    <!-- Stat Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Total Sales -->
        <a href="@Url.Action("GroupSales")" class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                    </svg>
                </div>
            </div>
            <p class="text-2xl font-bold text-gray-900">@totalSales</p>
            <p class="text-xs text-gray-500 mt-1">Total Group Sales</p>
        </a>

        <!-- Total Revenue -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 bg-green-50 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
            </div>
            <p class="text-2xl font-bold text-gray-900">$@totalRevenue.ToString("N0")</p>
            <p class="text-xs text-gray-500 mt-1">Total Revenue</p>
        </div>

        <!-- Pending / Tentative -->
        <a href="@Url.Action("GroupSales", new { status = "tentative" })" class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 bg-yellow-50 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                @if (pendingCount > 0)
                {
                    <span class="text-xs font-medium bg-yellow-100 text-yellow-700 px-2 py-0.5 rounded-full">Pending</span>
                }
            </div>
            <p class="text-2xl font-bold text-gray-900">@pendingCount</p>
            <p class="text-xs text-gray-500 mt-1">Tentative Sales</p>
        </a>

        <!-- Confirmed -->
        <a href="@Url.Action("GroupSales", new { status = "confirmed" })" class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 bg-emerald-50 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
            </div>
            <p class="text-2xl font-bold text-gray-900">@confirmedCount</p>
            <p class="text-xs text-gray-500 mt-1">Confirmed Sales</p>
        </a>
    </div>

    <!-- Quick Actions -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-sm font-semibold text-gray-700 mb-4">Quick Actions</h2>
        <div class="flex flex-wrap gap-3">
            <a href="@Url.Action("CreateGroupSale")" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors">
                + New Group Sale
            </a>
            <a href="@Url.Action("GroupSales")" class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-200 transition-colors">
                View All Sales
            </a>
            <a href="@Url.Action("Staff")" class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-200 transition-colors">
                Sales Staff
            </a>
        </div>
    </div>

    <!-- Recent Group Sales -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
            <h2 class="text-sm font-semibold text-gray-700">Recent Group Sales</h2>
            <a href="@Url.Action("GroupSales")" class="text-xs text-blue-600 hover:underline">View all</a>
        </div>

        @if (!recentSales.Any())
        {
            <div class="p-12 text-center">
                <p class="text-gray-400 text-sm">No group sales yet. Create your first one.</p>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-gray-100">
                            <th class="text-left text-xs font-medium text-gray-500 uppercase tracking-wide px-6 py-3">Group</th>
                            <th class="text-left text-xs font-medium text-gray-500 uppercase tracking-wide px-6 py-3">Contact</th>
                            <th class="text-left text-xs font-medium text-gray-500 uppercase tracking-wide px-6 py-3">Dates</th>
                            <th class="text-center text-xs font-medium text-gray-500 uppercase tracking-wide px-6 py-3">Rooms</th>
                            <th class="text-right text-xs font-medium text-gray-500 uppercase tracking-wide px-6 py-3">Revenue</th>
                            <th class="text-center text-xs font-medium text-gray-500 uppercase tracking-wide px-6 py-3">Status</th>
                            <th class="text-center text-xs font-medium text-gray-500 uppercase tracking-wide px-6 py-3">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        @foreach (var gs in recentSales)
                        {
                            var statusClass = gs.Status switch
                            {
                                "tentative" => "bg-yellow-100 text-yellow-700",
                                "confirmed" => "bg-green-100 text-green-700",
                                "cancelled" => "bg-red-100 text-red-700",
                                "completed" => "bg-blue-100 text-blue-700",
                                _ => "bg-gray-100 text-gray-600"
                            };

                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-3">
                                    <span class="text-sm font-medium text-gray-800">@gs.GroupName</span>
                                </td>
                                <td class="px-6 py-3 text-sm text-gray-600">@(gs.ContactName ?? "-")</td>
                                <td class="px-6 py-3 text-sm text-gray-600">
                                    @gs.CheckIn.ToString("MMM dd") - @gs.CheckOut.ToString("MMM dd, yyyy")
                                </td>
                                <td class="px-6 py-3 text-sm text-gray-600 text-center">@gs.RoomsBlocked</td>
                                <td class="px-6 py-3 text-sm font-medium text-gray-800 text-right">$@gs.Revenue.ToString("N0")</td>
                                <td class="px-6 py-3 text-center">
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium @statusClass">@gs.Status</span>
                                </td>
                                <td class="px-6 py-3 text-center">
                                    <a href="@Url.Action("EditGroupSale", new { id = gs.Id })" class="text-xs text-blue-600 hover:underline">Edit</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
