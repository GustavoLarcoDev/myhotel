@{
    ViewData["Title"] = "Staff Scheduling";

    var departments = ViewBag.Departments as List<Department> ?? new List<Department>();
    var selectedDeptId = (int)ViewBag.SelectedDepartmentId;
    var weekStart = (DateTime)ViewBag.WeekStart;
    var weekEnd = (DateTime)ViewBag.WeekEnd;
    var prevWeek = (string)ViewBag.PrevWeek;
    var nextWeek = (string)ViewBag.NextWeek;
    var weekDays = ViewBag.WeekDays as List<DateTime> ?? new List<DateTime>();
    var employees = ViewBag.Employees as List<ApplicationUser> ?? new List<ApplicationUser>();
    var schedules = ViewBag.Schedules as List<Schedule> ?? new List<Schedule>();
}

<!-- Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Staff Scheduling</h1>
        <p class="text-sm text-gray-500 mt-1">
            Week of @weekStart.ToString("MMM d") - @weekEnd.ToString("MMM d, yyyy")
        </p>
    </div>
    <div class="flex items-center gap-3">
        <!-- Department Dropdown -->
        <form method="get" class="flex items-center gap-2">
            <input type="hidden" name="weekStart" value="@weekStart.ToString("yyyy-MM-dd")" />
            <select name="departmentId" onchange="this.form.submit()"
                class="border border-gray-300 rounded-lg px-3 py-2 text-sm bg-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                <option value="0">-- Select Department --</option>
                @foreach (var dept in departments)
                {
                    <option value="@dept.Id" selected="@(selectedDeptId == dept.Id)">@dept.Name</option>
                }
            </select>
        </form>

        <!-- Week Navigation -->
        <div class="flex items-center gap-1">
            <a href="/Scheduling?departmentId=@selectedDeptId&weekStart=@prevWeek"
               class="p-2 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 text-gray-700 transition-colors">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            </a>
            <a href="/Scheduling?departmentId=@selectedDeptId"
               class="px-3 py-2 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 text-sm font-medium text-gray-700 transition-colors">Today</a>
            <a href="/Scheduling?departmentId=@selectedDeptId&weekStart=@nextWeek"
               class="p-2 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 text-gray-700 transition-colors">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
        </div>
    </div>
</div>

@if (selectedDeptId == 0)
{
    <div class="bg-blue-50 border border-blue-200 text-blue-700 px-6 py-12 rounded-lg text-center">
        <svg class="w-12 h-12 mx-auto mb-3 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <p class="text-lg font-medium">Select a Department</p>
        <p class="text-sm mt-1">Choose a department from the dropdown above to view and manage schedules.</p>
    </div>
}
else
{
    <div class="flex flex-col lg:flex-row gap-6">
        <!-- Week Grid -->
        <div class="flex-1 overflow-x-auto">
            <div class="bg-white rounded-lg border border-gray-200 shadow-sm min-w-[800px]">
                <!-- Grid Header -->
                <div class="grid grid-cols-8 border-b border-gray-200">
                    <div class="px-3 py-3 bg-gray-50 text-xs font-semibold text-gray-500 uppercase">Employee</div>
                    @foreach (var day in weekDays)
                    {
                        var isToday = day.Date == DateTime.Today;
                        <div class="px-2 py-3 text-center @(isToday ? "bg-blue-50" : "bg-gray-50")">
                            <div class="text-xs font-semibold @(isToday ? "text-blue-600" : "text-gray-500") uppercase">@day.ToString("ddd")</div>
                            <div class="text-sm font-bold @(isToday ? "text-blue-700" : "text-gray-700")">@day.Day</div>
                        </div>
                    }
                </div>

                <!-- Employee Rows -->
                @if (employees.Count == 0)
                {
                    <div class="px-6 py-8 text-center text-gray-500 text-sm">
                        No employees found in this department.
                    </div>
                }
                else
                {
                    @foreach (var emp in employees)
                    {
                        <div class="grid grid-cols-8 border-b border-gray-100 last:border-b-0">
                            <!-- Employee Name -->
                            <div class="px-3 py-3 flex items-center">
                                <div class="w-7 h-7 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center text-xs font-bold mr-2 flex-shrink-0">
                                    @(emp.FirstName.Length > 0 ? emp.FirstName[0] : "?")@(emp.LastName.Length > 0 ? emp.LastName[0] : "")
                                </div>
                                <span class="text-sm font-medium text-gray-900 truncate">@emp.FullName</span>
                            </div>

                            <!-- Day Cells -->
                            @foreach (var day in weekDays)
                            {
                                var isToday = day.Date == DateTime.Today;
                                var cellSchedules = schedules.Where(s => s.EmployeeId == emp.Id && s.Date.Date == day.Date).ToList();

                                <div class="px-1 py-2 border-l border-gray-100 @(isToday ? "bg-blue-50/30" : "") min-h-[60px]">
                                    @foreach (var sched in cellSchedules)
                                    {
                                        var start = DateTime.Today.Add(sched.StartTime);
                                        var end = DateTime.Today.Add(sched.EndTime);
                                        var isOvernight = sched.EndTime < sched.StartTime;
                                        <div class="@(isOvernight ? "bg-indigo-100 text-indigo-800 border border-indigo-200" : "bg-blue-100 text-blue-800") rounded px-1.5 py-1 text-xs mb-1 relative group">
                                            <div class="font-semibold">@start.ToString("h:mm tt") - @end.ToString("h:mm tt")@(isOvernight ? " +1" : "")</div>
                                            @if (!string.IsNullOrEmpty(sched.Notes))
                                            {
                                                <div class="text-blue-600 truncate text-[10px]">@sched.Notes</div>
                                            }
                                            <form method="post" action="/Scheduling/Delete" class="absolute -top-1 -right-1 hidden group-hover:block">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@sched.Id" />
                                                <input type="hidden" name="departmentId" value="@selectedDeptId" />
                                                <input type="hidden" name="weekStart" value="@weekStart.ToString("yyyy-MM-dd")" />
                                                <button type="submit" onclick="return confirm('Remove this schedule entry?')"
                                                    class="w-4 h-4 bg-red-500 text-white rounded-full flex items-center justify-center text-[10px] hover:bg-red-600 leading-none">
                                                    x
                                                </button>
                                            </form>
                                        </div>
                                    }

                                    @if (cellSchedules.Count == 0)
                                    {
                                        <!-- Inline add button that expands to a form -->
                                        <div x-data="{ open: false }" class="h-full">
                                            <button x-show="!open" @@click="open = true"
                                                class="w-full h-full min-h-[40px] border border-dashed border-gray-200 rounded text-gray-400 hover:text-blue-500 hover:border-blue-300 flex items-center justify-center transition-colors text-lg">
                                                +
                                            </button>
                                            <form x-show="open" method="post" action="/Scheduling/Create" class="space-y-1">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="departmentId" value="@selectedDeptId" />
                                                <input type="hidden" name="employeeId" value="@emp.Id" />
                                                <input type="hidden" name="date" value="@day.ToString("yyyy-MM-dd")" />
                                                <input type="hidden" name="weekStart" value="@weekStart.ToString("yyyy-MM-dd")" />
                                                <input type="time" name="startTime" value="07:00" required
                                                    class="w-full text-[10px] border border-gray-200 rounded px-1 py-0.5" />
                                                <input type="time" name="endTime" value="15:00" required
                                                    class="w-full text-[10px] border border-gray-200 rounded px-1 py-0.5" />
                                                <div class="flex gap-1">
                                                    <button type="submit" class="flex-1 bg-blue-500 text-white text-[10px] rounded px-1 py-0.5 hover:bg-blue-600">Add</button>
                                                    <button type="button" @@click="open = false" class="flex-1 bg-gray-200 text-gray-600 text-[10px] rounded px-1 py-0.5 hover:bg-gray-300">X</button>
                                                </div>
                                            </form>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Right Panel: Hours Summary -->
        <div class="lg:w-72 flex-shrink-0">
            <div class="bg-white rounded-lg border border-gray-200 shadow-sm">
                <div class="px-4 py-3 border-b border-gray-200">
                    <h2 class="text-sm font-semibold text-gray-900">Hours Summary</h2>
                    <p class="text-xs text-gray-500">Week of @weekStart.ToString("MMM d")</p>
                </div>
                <div class="divide-y divide-gray-100">
                    @if (employees.Count == 0)
                    {
                        <div class="px-4 py-6 text-center text-sm text-gray-400">No employees</div>
                    }
                    else
                    {
                        @foreach (var emp in employees)
                        {
                            var empSchedules = schedules.Where(s => s.EmployeeId == emp.Id).ToList();
                            var totalHours = empSchedules.Sum(s => s.EndTime >= s.StartTime
                                ? (s.EndTime - s.StartTime).TotalHours
                                : (TimeSpan.FromHours(24) - s.StartTime + s.EndTime).TotalHours);
                            var daysScheduled = empSchedules.Select(s => s.Date.Date).Distinct().Count();

                            <div class="px-4 py-3 flex items-center justify-between">
                                <div>
                                    <div class="text-sm font-medium text-gray-900">@emp.FullName</div>
                                    <div class="text-xs text-gray-500">@daysScheduled day@(daysScheduled != 1 ? "s" : "") scheduled</div>
                                </div>
                                <div class="text-right">
                                    <div class="text-sm font-bold @(totalHours > 40 ? "text-red-600" : "text-gray-900")">@totalHours.ToString("F1")h</div>
                                    @if (totalHours > 40)
                                    {
                                        <div class="text-[10px] text-red-500">Overtime</div>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

            <!-- Quick Add Form -->
            <div class="bg-white rounded-lg border border-gray-200 shadow-sm mt-4">
                <div class="px-4 py-3 border-b border-gray-200">
                    <h2 class="text-sm font-semibold text-gray-900">Add Schedule</h2>
                </div>
                <form method="post" action="/Scheduling/Create" class="p-4 space-y-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="departmentId" value="@selectedDeptId" />
                    <input type="hidden" name="weekStart" value="@weekStart.ToString("yyyy-MM-dd")" />

                    <div>
                        <label class="block text-xs font-medium text-gray-700 mb-1">Employee</label>
                        <select name="employeeId" required
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                            <option value="">Select employee...</option>
                            @foreach (var emp in employees)
                            {
                                <option value="@emp.Id">@emp.FullName</option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="block text-xs font-medium text-gray-700 mb-1">Date</label>
                        <input type="date" name="date" required value="@weekStart.ToString("yyyy-MM-dd")"
                            min="@weekStart.ToString("yyyy-MM-dd")" max="@weekEnd.ToString("yyyy-MM-dd")"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                    </div>

                    <div class="grid grid-cols-2 gap-2">
                        <div>
                            <label class="block text-xs font-medium text-gray-700 mb-1">Start</label>
                            <input type="time" name="startTime" value="07:00" required
                                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-700 mb-1">End</label>
                            <input type="time" name="endTime" value="15:00" required
                                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-medium text-gray-700 mb-1">Notes</label>
                        <input type="text" name="notes" placeholder="Optional notes..."
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                    </div>

                    <button type="submit"
                        class="w-full bg-blue-600 text-white py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors">
                        Add Schedule
                    </button>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
}
