@model List<Meeting>
@{
    var currentDept = ViewBag.CurrentDept as string;
    var deptName = ViewBag.DeptName as string;
    ViewData["Title"] = deptName != null ? $"{deptName} Meetings" : "Meetings";

    var upcoming = (bool)ViewBag.Upcoming;
    var departments = ViewBag.Departments as List<Department> ?? new List<Department>();
    var employees = ViewBag.Employees as List<ApplicationUser> ?? new List<ApplicationUser>();
    var userDepartments = ViewBag.UserDepartments as List<UserDepartment> ?? new List<UserDepartment>();
    var meetings = Model ?? new List<Meeting>();
}

<!-- Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">@(deptName != null ? $"{deptName} Meetings" : "Meetings")</h1>
        <p class="text-sm text-gray-500 mt-1">@meetings.Count @(upcoming ? "upcoming" : "past") meeting@(meetings.Count != 1 ? "s" : "")</p>
    </div>
    <div class="flex items-center gap-2">
        <a href="/Meetings?upcoming=true@(currentDept != null ? $"&dept={currentDept}" : "")"
           class="px-4 py-2 rounded-lg text-sm font-medium transition-colors @(upcoming ? "bg-blue-600 text-white" : "bg-white border border-gray-300 text-gray-700 hover:bg-gray-50")">
            Upcoming
        </a>
        <a href="/Meetings?upcoming=false@(currentDept != null ? $"&dept={currentDept}" : "")"
           class="px-4 py-2 rounded-lg text-sm font-medium transition-colors @(!upcoming ? "bg-blue-600 text-white" : "bg-white border border-gray-300 text-gray-700 hover:bg-gray-50")">
            Past
        </a>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Create Meeting Form -->
    <div class="lg:col-span-1">
        <div class="bg-white rounded-lg border border-gray-200 shadow-sm sticky top-24">
            <div class="px-4 py-3 border-b border-gray-200">
                <h2 class="text-sm font-semibold text-gray-900">Schedule Meeting</h2>
            </div>
            <form method="post" action="/Meetings/Create" class="p-4 space-y-3" x-data="meetingForm()" x-init="init()">
                @Html.AntiForgeryToken()
                @if (currentDept != null)
                {
                    <input type="hidden" name="dept" value="@currentDept" />
                }
                <div>
                    <label class="block text-xs font-medium text-gray-700 mb-1">Title *</label>
                    <input type="text" name="title" required placeholder="Meeting title..."
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                </div>

                <div>
                    <label class="block text-xs font-medium text-gray-700 mb-1">Description</label>
                    <textarea name="description" rows="2" placeholder="What is this meeting about?"
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"></textarea>
                </div>

                <div class="grid grid-cols-2 gap-2">
                    <div>
                        <label class="block text-xs font-medium text-gray-700 mb-1">Date *</label>
                        <input type="date" name="date" required value="@DateTime.Today.ToString("yyyy-MM-dd")"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-700 mb-1">Time *</label>
                        <input type="time" name="time" required value="09:00"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-medium text-gray-700 mb-1">Department</label>
                    <select name="departmentId" x-model="selectedDept" @@change="filterAttendees()"
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        <option value="0">All Departments</option>
                        @foreach (var dept in departments)
                        {
                            if (currentDept != null && string.Equals(dept.Name, deptName, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@dept.Id" selected>@dept.Name</option>
                            }
                            else
                            {
                                <option value="@dept.Id">@dept.Name</option>
                            }
                        }
                    </select>
                </div>

                <div>
                    <label class="block text-xs font-medium text-gray-700 mb-1">Attendees</label>
                    <div class="border border-gray-300 rounded-lg max-h-40 overflow-y-auto p-2 space-y-1">
                        @foreach (var emp in employees)
                        {
                            var empDeptIds = userDepartments.Where(ud => ud.UserId == emp.Id).Select(ud => ud.DepartmentId).ToList();
                            <label class="flex items-center gap-2 px-2 py-1 rounded hover:bg-gray-50 cursor-pointer attendee-item"
                                   data-departments="@string.Join(",", empDeptIds)">
                                <input type="checkbox" name="attendeeIds" value="@emp.Id"
                                    class="rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
                                <span class="text-sm text-gray-700">@emp.FullName</span>
                            </label>
                        }
                    </div>
                    <button type="button" onclick="toggleAllAttendees(this)" class="text-xs text-blue-600 hover:text-blue-800 mt-1">Select All Visible</button>
                </div>

                <button type="submit"
                    class="w-full bg-blue-600 text-white py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors">
                    Create Meeting
                </button>
            </form>
        </div>
    </div>

    <!-- Meetings List -->
    <div class="lg:col-span-2 space-y-4">
        @if (meetings.Count == 0)
        {
            <div class="bg-white rounded-lg border border-gray-200 px-6 py-12 text-center">
                <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <p class="text-gray-500">No @(upcoming ? "upcoming" : "past") meetings found.</p>
            </div>
        }

        @foreach (var meeting in meetings)
        {
            var meetingDateTime = meeting.Date.Add(meeting.Time);
            var isPast = meeting.Date.Date < DateTime.UtcNow.Date;
            var attendedCount = meeting.Attendees.Count(a => a.Attended);
            var totalAttendees = meeting.Attendees.Count;

            <div class="bg-white rounded-lg border border-gray-200 shadow-sm @(isPast ? "opacity-75" : "")" x-data="{ showNotes: false, showAttendees: true }">
                <!-- Meeting Header -->
                <div class="px-5 py-4 border-b border-gray-100">
                    <div class="flex items-start justify-between">
                        <div>
                            <h3 class="text-lg font-semibold text-gray-900">@meeting.Title</h3>
                            <div class="flex items-center gap-3 mt-1 text-sm text-gray-500">
                                <span class="flex items-center gap-1">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                    @meeting.Date.ToString("ddd, MMM d yyyy")
                                </span>
                                <span class="flex items-center gap-1">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                    @DateTime.Today.Add(meeting.Time).ToString("h:mm tt")
                                </span>
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            @if (meeting.Department != null)
                            {
                                <span class="px-2.5 py-1 bg-purple-100 text-purple-700 rounded-full text-xs font-medium">@meeting.Department.Name</span>
                            }
                            else
                            {
                                <span class="px-2.5 py-1 bg-gray-100 text-gray-600 rounded-full text-xs font-medium">All Departments</span>
                            }
                            <form method="post" action="/Meetings/Delete">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@meeting.Id" />
                                @if (currentDept != null)
                                {
                                    <input type="hidden" name="dept" value="@currentDept" />
                                }
                                <button type="submit" onclick="return swalConfirmBtn(this, 'Delete this meeting?')"
                                    class="p-1.5 text-gray-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                </button>
                            </form>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(meeting.Description))
                    {
                        <p class="text-sm text-gray-600 mt-2">@meeting.Description</p>
                    }
                </div>

                <!-- Attendees -->
                @if (totalAttendees > 0)
                {
                    <div class="px-5 py-3 border-b border-gray-100">
                        <button @@click="showAttendees = !showAttendees" class="flex items-center gap-2 text-sm font-medium text-gray-700 hover:text-gray-900 w-full">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                            Attendees (@attendedCount/@totalAttendees present)
                            <svg class="w-3 h-3 ml-auto transition-transform" :class="showAttendees ? 'rotate-180' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </button>
                        <div x-show="showAttendees" class="mt-2 grid grid-cols-1 sm:grid-cols-2 gap-1">
                            @foreach (var attendee in meeting.Attendees.OrderBy(a => a.User.FirstName))
                            {
                                <div class="flex items-center justify-between py-1.5 px-2 rounded hover:bg-gray-50">
                                    <div class="flex items-center gap-2">
                                        <div class="w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-bold @(attendee.Attended ? "bg-green-100 text-green-600" : "bg-gray-100 text-gray-500")">
                                            @(attendee.User.FirstName.Length > 0 ? attendee.User.FirstName[0] : "?")@(attendee.User.LastName.Length > 0 ? attendee.User.LastName[0] : "")
                                        </div>
                                        <span class="text-sm @(attendee.Attended ? "text-gray-900" : "text-gray-500")">@attendee.User.FullName</span>
                                    </div>
                                    <form method="post" action="/Meetings/ToggleAttendance">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="attendeeId" value="@attendee.Id" />
                                        @if (currentDept != null)
                                        {
                                            <input type="hidden" name="dept" value="@currentDept" />
                                        }
                                        <button type="submit"
                                            class="w-5 h-5 rounded flex items-center justify-center border @(attendee.Attended ? "bg-green-500 border-green-500 text-white" : "border-gray-300 hover:border-green-400") transition-colors">
                                            @if (attendee.Attended)
                                            {
                                                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                                            }
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Notes Section -->
                <div class="px-5 py-3">
                    @if (!string.IsNullOrEmpty(meeting.Notes))
                    {
                        <div class="mb-2">
                            <span class="text-xs font-semibold text-gray-500 uppercase">Notes</span>
                            <p class="text-sm text-gray-700 mt-1 whitespace-pre-line bg-amber-50 border border-amber-100 rounded-lg p-3">@meeting.Notes</p>
                        </div>
                    }
                    <button @@click="showNotes = !showNotes" class="text-xs text-blue-600 hover:text-blue-800 font-medium">
                        <span x-text="showNotes ? 'Cancel' : '@(string.IsNullOrEmpty(meeting.Notes) ? "Add Notes" : "Edit Notes")'"></span>
                    </button>
                    <form x-show="showNotes" method="post" action="/Meetings/AddNotes" class="mt-2 flex gap-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@meeting.Id" />
                        @if (currentDept != null)
                        {
                            <input type="hidden" name="dept" value="@currentDept" />
                        }
                        <textarea name="notes" rows="2" placeholder="Add meeting notes..."
                            class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">@meeting.Notes</textarea>
                        <button type="submit" class="px-3 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors self-end">Save</button>
                    </form>
                </div>

                <!-- Footer -->
                <div class="px-5 py-2 bg-gray-50 rounded-b-lg text-xs text-gray-400">
                    Created by @meeting.CreatedBy on @meeting.CreatedAt.ToString("MMM d, yyyy h:mm tt")
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <script>
        function meetingForm() {
            return {
                selectedDept: '0',
                init() {
                    const select = this.$el.querySelector('select[name="departmentId"]');
                    if (select && select.value !== '0') {
                        this.selectedDept = select.value;
                        this.filterAttendees();
                    }
                },
                filterAttendees() {
                    const deptId = this.selectedDept;
                    document.querySelectorAll('.attendee-item').forEach(item => {
                        if (deptId === '0') {
                            item.style.display = '';
                        } else {
                            const depts = item.getAttribute('data-departments').split(',');
                            item.style.display = depts.includes(deptId) ? '' : 'none';
                            if (!depts.includes(deptId)) {
                                item.querySelector('input[type=checkbox]').checked = false;
                            }
                        }
                    });
                }
            };
        }

        function toggleAllAttendees(btn) {
            const container = btn.previousElementSibling;
            const visibleCheckboxes = container.querySelectorAll('.attendee-item:not([style*="display: none"]) input[type=checkbox]');
            const allChecked = Array.from(visibleCheckboxes).every(cb => cb.checked);
            visibleCheckboxes.forEach(cb => cb.checked = !allChecked);
            btn.textContent = allChecked ? 'Select All Visible' : 'Deselect All';
        }
    </script>
}
